@inherits LayoutComponentBase
@rendermode InteractiveServer
@inject IJSRuntime JS

<TelerikRootComponent>
    <div class="app-shell">
        <header class="app-shell__header">
            <div>
                <div class="app-shell__title">IIS Log Viewer</div>
                <div class="app-shell__subtitle">W3SVC2 analytics workspace</div>
            </div>

            <div class="app-shell__theme-picker">
                <label class="app-shell__label" for="theme-selector">Theme</label>
                <TelerikDropDownList Id="theme-selector"
                                     Data="@Themes"
                                     TextField="@nameof(ThemeOption.Text)"
                                     ValueField="@nameof(ThemeOption.Value)"
                                     Value="@SelectedTheme"
                                     ValueChanged="@( (string value) => OnThemeChanged(value) )"
                                     Width="200px"
                                     Size="@ThemeConstants.DropDownList.Size.Small"
                                     FillMode="@ThemeConstants.DropDownList.FillMode.Outline" />
            </div>
        </header>

        <div class="app-shell__body">
            <aside class="app-shell__sidebar">
                <div class="app-shell__sidebar-title">Log Files</div>
                <NavMenu />
            </aside>

            <main class="app-shell__content">
                @Body
            </main>
        </div>
    </div>
</TelerikRootComponent>

<style>
    .app-shell {
        min-height: 100vh;
        background-color: var(--kendo-color-app-surface, #f5f5f5);
        color: var(--kendo-color-on-app-surface, inherit);
    }

    .app-shell__header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        padding: 0.75rem 1rem 0.55rem;
        border-bottom: 1px solid var(--kendo-color-border, #d4d4d4);
        background-color: var(--kendo-color-surface, #ffffff);
        position: sticky;
        top: 0;
        z-index: 20;
    }

    .app-shell__title {
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .app-shell__subtitle,
    .app-shell__label {
        color: var(--kendo-color-on-surface, inherit);
        font-size: 0.72rem;
        line-height: 1.2;
    }

    .app-shell__theme-picker {
        min-width: 220px;
    }

    .app-shell__body {
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        gap: 0.9rem;
        padding: 0.8rem;
    }

    .app-shell__sidebar,
    .app-shell__content {
        background: var(--kendo-color-surface, #ffffff);
        border: 1px solid var(--kendo-color-border, #d4d4d4);
        border-radius: 12px;
    }

    .app-shell__sidebar {
        padding: 1rem 0.75rem;
        position: sticky;
        top: 6.25rem;
        max-height: calc(100vh - 7.5rem);
        overflow: auto;
    }

    .app-shell__sidebar-title {
        padding: 0 0.5rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--kendo-color-subtle, #666);
    }

    .app-shell__content { padding: 0.85rem; }

    @@media (max-width: 960px) {
        .app-shell__body {
            grid-template-columns: 1fr;
        }

        .app-shell__sidebar {
            position: static;
            max-height: none;
        }

        .app-shell__header {
            align-items: start;
            flex-direction: column;
        }
    }
</style>

@code {
    public class ThemeOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private string SelectedTheme = "_content/Telerik.UI.for.Blazor/css/kendo-theme-default/all.css";

    private readonly List<ThemeOption> Themes = new()
    {
        new ThemeOption { Text = "Default", Value = "_content/Telerik.UI.for.Blazor/css/kendo-theme-default/all.css" },
        new ThemeOption { Text = "Bootstrap", Value = "_content/Telerik.UI.for.Blazor/css/kendo-theme-bootstrap/all.css" },
        new ThemeOption { Text = "Material", Value = "_content/Telerik.UI.for.Blazor/css/kendo-theme-material/all.css" },
        new ThemeOption { Text = "Fluent", Value = "_content/Telerik.UI.for.Blazor/css/kendo-theme-fluent/all.css" }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeSwitcher.getTheme");

            if (!string.IsNullOrWhiteSpace(theme))
            {
                SelectedTheme = Themes.Any(t => string.Equals(t.Value, theme, StringComparison.OrdinalIgnoreCase))
                    ? theme
                    : "_content/Telerik.UI.for.Blazor/css/kendo-theme-default/all.css";
                await InvokeAsync(StateHasChanged);
            }
        }

        // Re-apply the currently selected theme after renders so tab switches
        // or component refreshes cannot visually reset the active stylesheet.
        await JS.InvokeVoidAsync("themeSwitcher.setTheme", SelectedTheme);
    }

    private async Task OnThemeChanged(string value)
    {
        SelectedTheme = string.IsNullOrWhiteSpace(value)
            ? "_content/Telerik.UI.for.Blazor/css/kendo-theme-default/all.css"
            : value;

        await JS.InvokeVoidAsync("themeSwitcher.setTheme", SelectedTheme);
    }
}
