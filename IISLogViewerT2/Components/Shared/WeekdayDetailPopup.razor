@inject IISLogViewer.Services.LogParserService LogParserService

@if (IsOpen)
{
    <TelerikWindow Width="1020px"
                   Height="680px"
                   Visible="@IsOpen"
                   Modal="true"
                   Draggable="true"
                   Resizable="true"
                   Class="popup-window popup-window--weekday">
        <WindowTitle>
            Weekday Details - @SelectedWeekdayLabel
        </WindowTitle>
        <WindowActions>
            <WindowAction Name="Close" />
        </WindowActions>
        <WindowContent>
            <TelerikTabStrip Class="popup-tabs">
                        <TabStripTab Title="🔥 Top Pages">
                            @if (!TopPagesRows.Any())
                            {
                                <div class="text-muted small">No page hits for this day.</div>
                            }
                            else
                            {
                                <div class="weekday-section__content">
                                    <TelerikGrid Data="@TopPagesRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Page" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
                        <TabStripTab Title="📄 Top Documents">
                            @if (!TopDocumentsRows.Any())
                            {
                                <div class="text-muted small">No document hits for this day.</div>
                            }
                            else
                            {
                                <div class="weekday-section__content">
                                    <TelerikGrid Data="@TopDocumentsRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Document" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
                        <TabStripTab Title="🪟 Top Popups">
                            @if (!TopPopupsRows.Any())
                            {
                                <div class="text-muted small">No popup hits for this day.</div>
                            }
                            else
                            {
                                <div class="weekday-section__content">
                                    <TelerikGrid Data="@TopPopupsRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Popup" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
                        <TabStripTab Title="👤 Most Active Users">
                            @if (!TopUsersRows.Any())
                            {
                                <div class="text-muted small">No user hits for this day.</div>
                            }
                            else
                            {
                                <div class="weekday-section__content">
                                    <TelerikGrid Data="@TopUsersRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="User" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
                        <TabStripTab Title="⏰ Most Active Hours">
                            @if (!TopHoursRows.Any())
                            {
                                <div class="text-muted small">No hourly hits for this day.</div>
                            }
                            else
                            {
                                <div class="weekday-section__content">
                                    <TelerikGrid Data="@TopHoursRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(HourHitRow.HourLabel)" Title="Hour" />
                                            <GridColumn Field="@nameof(HourHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (HourHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
            </TelerikTabStrip>

        </WindowContent>
    </TelerikWindow>
}

<style>
    .popup-window {
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 22px 50px rgba(0, 0, 0, 0.18);
    }

    .popup-window :is(.k-window-titlebar, .k-dialog-titlebar) {
        background: linear-gradient(120deg, var(--kendo-color-primary, #0d6efd), color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 40%, #0b1324));
        color: #fff;
        font-weight: 700;
        letter-spacing: 0.01em;
    }

    .popup-window .k-window-content {
        background: color-mix(in srgb, var(--kendo-color-surface, #fff) 88%, var(--kendo-color-app-surface, #f5f5f5));
        padding: 0.35rem;
    }

    .popup-tabs {
        margin-top: 0.1rem;
    }

    .weekday-section__content {
        padding: 0.45rem 0.1rem 0.2rem;
    }
</style>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public int SelectedWeekday { get; set; }

    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private const int MaxRows = 12;

    private string SelectedWeekdayLabel => DayLabel(SelectedWeekday);

    private List<ItemHitRow> TopPagesRows => MapRows(GetTopByWeekday(ReportData?.WeekdayPageHits, SelectedWeekday));
    private List<ItemHitRow> TopPopupsRows => MapRows(GetTopByWeekday(ReportData?.WeekdayPopupHits, SelectedWeekday));
    private List<ItemHitRow> TopDocumentsRows => MapRows(GetTopByWeekday(ReportData?.WeekdayDocumentHits, SelectedWeekday));
    private List<ItemHitRow> TopUsersRows => MapRows(GetTopUsersByWeekday(ReportData?.WeekdayUserHits, SelectedWeekday));
    private List<HourHitRow> TopHoursRows => GetTopHoursByWeekday(ReportData?.WeekdayHourHits, SelectedWeekday)
        .Select(x => new HourHitRow($"{x.Key:D2}:00-{x.Key:D2}:59", x.Value))
        .ToList();

    private static IEnumerable<KeyValuePair<string, int>> GetTopByWeekday(
        Dictionary<int, Dictionary<string, int>>? source,
        int weekday)
    {
        if (source == null || !source.TryGetValue(weekday, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<string, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Take(MaxRows);
    }

    private IEnumerable<KeyValuePair<string, int>> GetTopUsersByWeekday(
        Dictionary<int, Dictionary<string, int>>? source,
        int weekday)
    {
        if (source == null || !source.TryGetValue(weekday, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<string, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Take(MaxRows)
            .Select(item =>
            {
                var displayName = LogParserService.GetUserDisplayName(item.Key);
                var label = string.Equals(displayName, item.Key, StringComparison.OrdinalIgnoreCase)
                    ? item.Key
                    : $"{displayName} ({item.Key})";
                return new KeyValuePair<string, int>(label, item.Value);
            });
    }

    private static IEnumerable<KeyValuePair<int, int>> GetTopHoursByWeekday(
        Dictionary<int, Dictionary<int, int>>? source,
        int weekday)
    {
        if (source == null || !source.TryGetValue(weekday, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<int, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key)
            .Take(MaxRows);
    }

    private static string DayLabel(int dayIndex)
    {
        if (dayIndex is < 0 or > 6)
            return $"Day {dayIndex}";

        return ((DayOfWeek)dayIndex).ToString();
    }

    private static List<ItemHitRow> MapRows(IEnumerable<KeyValuePair<string, int>> source) =>
        source.Select(x => new ItemHitRow(x.Key, x.Value)).ToList();

    private Task Close() => OnClose.InvokeAsync();

    private sealed record ItemHitRow(string Item, int Hits);
    private sealed record HourHitRow(string HourLabel, int Hits);
}
