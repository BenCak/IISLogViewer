@if (IsOpen)
{
    <TelerikWindow Width="1320px"
                   Height="700px"
                   Visible="@IsOpen"
                   VisibleChanged="OnWindowVisibleChanged"
                   Modal="true"
                   Draggable="true"
                   Resizable="true"
                   Class="popup-window popup-window--user">
        <WindowTitle>
            User Details - @HeaderDisplayName
        </WindowTitle>
        <WindowActions>
            <WindowAction Name="Close" />
        </WindowActions>
        <WindowContent>
            <div class="text-muted small mb-2">@HeaderSubTitle</div>

            @if (_isInitializing)
            {
                <div class="popup-global-loading">
                    <TelerikLoader Size="@ThemeConstants.Loader.Size.Large" Type="@LoaderType.InfiniteSpinner" />
                    <span>Loading user data…</span>
                </div>
            }
            else
            {

            <div class="user-peak-summary">
                @if (PeakHourSummary is not null)
                {
                    <span>Most Active Hour: <strong>@PeakHourSummary.HourLabel</strong>
                        <span class="text-muted">(@PeakHourSummary.Hits.ToString("N0") hits, @PeakHourSummary.PercentageLabel)</span>
                    </span>
                    <span class="mx-2 text-muted">·</span>
                }
                <span>Traffic Share: <strong>@TrafficSharePercent.ToString("F1")%</strong>
                    <span class="text-muted">(@SelectedUserTotalHits.ToString("N0") of @(ReportData?.TotalHits.ToString("N0")) total hits)</span>
                </span>
            </div>

            <TelerikTabStrip Class="popup-tabs">
                <TabStripTab Title="🔥 Top Pages">
                    @if (!TopPagesRows.Any())
                    {
                        <div class="text-muted small">No page hits for this user.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@TopPagesRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Page" />
                                    <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                        <Template Context="itemObj">
                                            @{ var row = (ItemHitRow)itemObj; }
                                            <div class="text-start">@row.Hits.ToString("N0")</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
                <TabStripTab Title="📄 Top Documents">
                    @if (!TopDocumentsRows.Any())
                    {
                        <div class="text-muted small">No document hits for this user.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@TopDocumentsRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Document" />
                                    <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                        <Template Context="itemObj">
                                            @{ var row = (ItemHitRow)itemObj; }
                                            <div class="text-start">@row.Hits.ToString("N0")</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
                <TabStripTab Title="🪟 Top Popups">
                    @if (!TopPopupsRows.Any())
                    {
                        <div class="text-muted small">No popup hits for this user.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@TopPopupsRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Popup" />
                                    <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                        <Template Context="itemObj">
                                            @{ var row = (ItemHitRow)itemObj; }
                                            <div class="text-start">@row.Hits.ToString("N0")</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
                <TabStripTab Title="📅 Most Active Weekdays">
                    @if (!WeekdayRows.Any())
                    {
                        <div class="text-muted small">No weekday activity for this user.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@WeekdayRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(WeekdayRow.DayLabel)" Title="Day" Width="140px" />
                                    <GridColumn Field="@nameof(WeekdayRow.HitsLabel)" Title="Hits" Width="110px">
                                        <Template Context="itemObj">
                                            @{ var row = (WeekdayRow)itemObj; }
                                            <div class="text-start">@row.HitsLabel</div>
                                        </Template>
                                    </GridColumn>
                                    <GridColumn Field="@nameof(WeekdayRow.PercentLabel)" Title="Percent" Width="120px">
                                        <Template Context="itemObj">
                                            @{ var row = (WeekdayRow)itemObj; }
                                            <div class="text-start">@row.PercentLabel</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
                <TabStripTab Title="⏰ Most Active Hours">
                    @if (!TopHoursRows.Any())
                    {
                        <div class="text-muted small">No hourly activity for this user.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@TopHoursRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(HourHitRow.HourLabel)" Title="Hour" />
                                    <GridColumn Field="@nameof(HourHitRow.Hits)" Title="Hits" Width="110px">
                                        <Template Context="itemObj">
                                            @{ var row = (HourHitRow)itemObj; }
                                            <div class="text-start">@row.Hits.ToString("N0")</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
                <TabStripTab Title="📊 Status Code Breakdown">
                    @if (!TopStatusRows.Any())
                    {
                        <div class="text-muted small">No status code data for this user.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@TopStatusRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Status" />
                                    <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                        <Template Context="itemObj">
                                            @{ var row = (ItemHitRow)itemObj; }
                                            <div class="text-start">@row.Hits.ToString("N0")</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
                <TabStripTab Title="🧭 Timeline">
                    <div class="user-timeline-toolbar">
                        <TelerikDropDownList Data="@_timelineDateOptions"
                                             TextField="@nameof(TimelineDateOption.Text)"
                                             ValueField="@nameof(TimelineDateOption.Value)"
                                             Value="@_selectedTimelineDateKey"
                                             ValueChanged="@( (string value) => OnTimelineDateChanged(value) )"
                                             DefaultText="Select date"
                                             Width="190px"
                                             Size="@ThemeConstants.DropDownList.Size.Small"
                                             FillMode="@ThemeConstants.DropDownList.FillMode.Outline" />
                    </div>

                    @if (_timelineLoading)
                    {
                        <div class="loading-state">
                            <TelerikLoader Size="@ThemeConstants.Loader.Size.Medium" Type="@LoaderType.InfiniteSpinner" />
                            <span>Loading timeline...</span>
                        </div>
                    }
                    else if (!_timelineRows.Any())
                    {
                        <div class="text-muted small">No timeline events for this user and date.</div>
                    }
                    else
                    {
                        <div class="user-section__content">
                            <TelerikGrid Data="@_timelineRows" Pageable="true" @bind-PageSize="_gridPageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(UserTimelineRow.TimeLabel)" Title="Time" Width="120px" />
                                    <GridColumn Field="@nameof(UserTimelineRow.Action)" Title="Action" />
                                    <GridColumn Field="@nameof(UserTimelineRow.EventType)" Title="Type" Width="100px" />
                                    <GridColumn Field="@nameof(UserTimelineRow.StatusLabel)" Title="Status" Width="95px" />
                                    <GridColumn Field="@nameof(UserTimelineRow.DurationLabel)" Title="Duration" Width="120px" />
                                </GridColumns>
                            </TelerikGrid>
                        </div>
                    }
                </TabStripTab>
            </TelerikTabStrip>

            } @* end else (not initializing) *@

        </WindowContent>
    </TelerikWindow>
}

<style>
    .popup-window {
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 22px 50px rgba(0, 0, 0, 0.18);
    }

    .popup-window :is(.k-window-titlebar, .k-dialog-titlebar) {
        background: linear-gradient(120deg, var(--kendo-color-primary, #0d6efd), color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 40%, #0b1324));
        color: #fff;
        font-weight: 700;
        letter-spacing: 0.01em;
    }

    .popup-window .k-window-content {
        background: color-mix(in srgb, var(--kendo-color-surface, #fff) 88%, var(--kendo-color-app-surface, #f5f5f5));
        padding: 0.35rem;
    }

    .user-peak-summary {
        margin-bottom: 0.55rem;
        padding: 0.55rem 0.7rem;
        border: 1px solid var(--kendo-color-border, #d4d4d4);
        border-radius: 10px;
        background: linear-gradient(120deg, color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 10%, #fff), #fff);
        font-size: 0.9rem;
    }

    .popup-tabs {
        margin-top: 0.1rem;
    }

    .user-timeline-toolbar {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 0.45rem;
    }

    .loading-state {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--kendo-color-subtle, #666);
        padding: 0.35rem 0.1rem;
    }

    .popup-global-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        padding: 3rem 1rem;
        color: var(--kendo-color-subtle, #666);
        font-size: 0.95rem;
    }

    .user-section__content {
        padding: 0.45rem 0.1rem 0.2rem;
    }
</style>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string SelectedUser { get; set; } = "";

    [Parameter]
    public string SelectedUserDisplayName { get; set; } = "";

    [Parameter]
    public IEnumerable<DateTime>? SelectedDays { get; set; }

    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    [Inject]
    public IISLogViewer.Services.LogParserService LogParserService { get; set; } = default!;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnReady { get; set; }

    private string _timelineUserSeed = "";
    private string _timelineSelectionSeed = "";
    private string _selectedTimelineDateKey = "";
    private List<TimelineDateOption> _timelineDateOptions = new();
    private List<UserTimelineRow> _timelineRows = new();
    private bool _timelineLoading;
    private bool _isInitializing;
    private int _gridPageSize = 10;

    private const int MaxRows = 12;

    private IISLogViewer.Services.UserProfile? SelectedProfile =>
        string.IsNullOrWhiteSpace(SelectedUser) ? null : LogParserService.GetUserProfile(SelectedUser);

    private string HeaderDisplayName =>
        string.IsNullOrWhiteSpace(SelectedUserDisplayName) ? SelectedUser : SelectedUserDisplayName;

    private string HeaderSubTitle
    {
        get
        {
            var parts = new List<string> { SelectedUser };
            if (!string.IsNullOrWhiteSpace(SelectedProfile?.Department))
                parts.Add(SelectedProfile.Department);
            if (!string.IsNullOrWhiteSpace(SelectedProfile?.Email))
                parts.Add(SelectedProfile.Email);
            return string.Join(" | ", parts.Where(x => !string.IsNullOrWhiteSpace(x)));
        }
    }

    private List<ItemHitRow> TopPagesRows => MapRows(GetTopByUser(ReportData?.UserPageHits, SelectedUser));
    private List<ItemHitRow> TopDocumentsRows => MapRows(GetTopByUser(ReportData?.UserDocumentHits, SelectedUser));
    private List<ItemHitRow> TopPopupsRows => MapRows(GetTopByUser(ReportData?.UserPopupHits, SelectedUser));
    private List<ItemHitRow> TopStatusRows => GetTopStatusByUser(ReportData?.UserStatusHits, SelectedUser)
        .Select(item => new ItemHitRow(IISLogViewer.Services.LogParserService.GetStatusDisplay(item.Key), item.Value))
        .ToList();
    private List<HourHitRow> TopHoursRows => GetTopHoursByUser(ReportData?.UserHourlyHits, SelectedUser)
        .Select(item => new HourHitRow($"{item.Key:D2}:00-{item.Key:D2}:59", item.Value))
        .ToList();

    private PeakHourInfo? PeakHourSummary => BuildPeakHour(ReportData?.UserHourlyHits, SelectedUser, SelectedUserTotalHits);

    private int SelectedUserTotalHits => ReportData?.UserHits.TryGetValue(SelectedUser, out var hits) == true ? hits : 0;

    private double TrafficSharePercent => ReportData?.TotalHits > 0
        ? Math.Round(SelectedUserTotalHits * 100.0 / ReportData.TotalHits, 1)
        : 0.0;

    private List<WeekdayRow> WeekdayRows => BuildWeekdayRows(ReportData?.UserWeekdayHits, SelectedUser, SelectedUserTotalHits).ToList();

    protected override async Task OnParametersSetAsync()
    {
        var currentSelectionSeed = BuildSelectionSeed(SelectedDays);

        if (!IsOpen || string.IsNullOrWhiteSpace(SelectedUser))
        {
            _timelineUserSeed = "";
            _timelineSelectionSeed = "";
            _selectedTimelineDateKey = "";
            _timelineDateOptions = new List<TimelineDateOption>();
            _timelineRows = new List<UserTimelineRow>();
            return;
        }

        if (string.Equals(_timelineUserSeed, SelectedUser, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(_timelineSelectionSeed, currentSelectionSeed, StringComparison.Ordinal) &&
            _timelineDateOptions.Count > 0)
            return;

        _timelineUserSeed = SelectedUser;
        _timelineSelectionSeed = currentSelectionSeed;
        await RefreshTimelineDatesAsync();
    }

    private async Task RefreshTimelineDatesAsync()
    {
        _isInitializing = true;
        StateHasChanged();
        List<DateTime> dates;
        try
        {
            dates = await LogParserService.GetTimelineDatesForUser(SelectedUser);
        }
        finally
        {
            _isInitializing = false;
            await OnReady.InvokeAsync();
        }

        var selectedDaySet = SelectedDays?
            .Select(d => d.Date)
            .ToHashSet() ?? new HashSet<DateTime>();

        if (selectedDaySet.Count > 0)
            dates = dates.Where(d => selectedDaySet.Contains(d.Date)).ToList();

        _timelineDateOptions = dates
            .Select(d => new TimelineDateOption(d.ToString("dd MMM yyyy"), d.ToString("yyyy-MM-dd")))
            .ToList();

        _selectedTimelineDateKey = _timelineDateOptions.FirstOrDefault()?.Value ?? string.Empty;
        StateHasChanged();
        await LoadTimelineAsync();
    }

    private async Task OnTimelineDateChanged(string value)
    {
        _selectedTimelineDateKey = value ?? string.Empty;
        await LoadTimelineAsync();
    }

    private async Task LoadTimelineAsync()
    {
        if (string.IsNullOrWhiteSpace(SelectedUser) ||
            string.IsNullOrWhiteSpace(_selectedTimelineDateKey) ||
            !DateTime.TryParse(_selectedTimelineDateKey, out var selectedDate))
        {
            _timelineRows = new List<UserTimelineRow>();
            return;
        }

        _timelineLoading = true;
        try
        {
            var events = await LogParserService.ParseTimelineDayForUser(selectedDate.Date, SelectedUser);
            var orderedEvents = events
                .OrderBy(e => e.TimestampLocal)
                .ToList();

            _timelineRows = CombineTimelineRows(orderedEvents)
                .Select(row => new UserTimelineRow(
                    row.TimestampLocal.ToString("HH:mm:ss"),
                    row.Count > 1 ? $"{row.Action} (x{row.Count})" : row.Action,
                    row.EventType,
                    row.StatusLabel,
                    row.DurationMs > 0 ? $"{row.DurationMs:N0} ms" : "-"))
                .ToList();
        }
        finally
        {
            _timelineLoading = false;
        }
    }

    private static IEnumerable<KeyValuePair<string, int>> GetTopByUser(
        Dictionary<string, Dictionary<string, int>>? source,
        string user)
    {
        if (source == null || string.IsNullOrWhiteSpace(user) || !source.TryGetValue(user, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<string, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Take(MaxRows);
    }

    private static IEnumerable<KeyValuePair<int, int>> GetTopStatusByUser(
        Dictionary<string, Dictionary<int, int>>? source,
        string user)
    {
        if (source == null || string.IsNullOrWhiteSpace(user) || !source.TryGetValue(user, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<int, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key)
            .Take(MaxRows);
    }

    private static IEnumerable<KeyValuePair<int, int>> GetTopHoursByUser(
        Dictionary<string, Dictionary<int, int>>? source,
        string user)
    {
        if (source == null || string.IsNullOrWhiteSpace(user) || !source.TryGetValue(user, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<int, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key)
            .Take(MaxRows);
    }

    private static PeakHourInfo? BuildPeakHour(
        Dictionary<string, Dictionary<int, int>>? source,
        string user,
        int totalHits)
    {
        if (totalHits <= 0)
            return null;

        if (source == null || string.IsNullOrWhiteSpace(user) || !source.TryGetValue(user, out var bucket) || bucket.Count == 0)
            return null;

        var peak = bucket
            .OrderByDescending(x => x.Value)
            .ThenByDescending(x => x.Key)
            .First();

        if (peak.Value <= 0)
            return null;

        var percent = (peak.Value * 100.0) / totalHits;
        return new PeakHourInfo($"{peak.Key:D2}:00-{peak.Key:D2}:59", peak.Value, $"{percent:F1}% of user traffic");
    }

    private static IEnumerable<WeekdayRow> BuildWeekdayRows(
        Dictionary<string, Dictionary<int, int>>? source,
        string user,
        int totalHits)
    {
        var weekdayOrder = new[]
        {
            DayOfWeek.Monday,
            DayOfWeek.Tuesday,
            DayOfWeek.Wednesday,
            DayOfWeek.Thursday,
            DayOfWeek.Friday,
            DayOfWeek.Saturday,
            DayOfWeek.Sunday
        };

        var bucket = (source != null && !string.IsNullOrWhiteSpace(user) && source.TryGetValue(user, out var found))
            ? found
            : new Dictionary<int, int>();

        foreach (var day in weekdayOrder)
        {
            var key = (int)day;
            var hits = bucket.TryGetValue(key, out var value) ? value : 0;
            var pct = totalHits > 0 ? (hits * 100.0) / totalHits : 0;
            yield return new WeekdayRow(day.ToString()[..3], hits.ToString("N0"), $"{pct:F1}%");
        }
    }

    private static List<ItemHitRow> MapRows(IEnumerable<KeyValuePair<string, int>> source) =>
        source.Select(x => new ItemHitRow(x.Key, x.Value)).ToList();

    private static string BuildSelectionSeed(IEnumerable<DateTime>? selectedDays)
    {
        if (selectedDays == null)
            return string.Empty;

        return string.Join("|", selectedDays
            .Select(d => d.Date)
            .Distinct()
            .OrderBy(d => d)
            .Select(d => d.ToString("yyyy-MM-dd")));
    }

    private Task Close() => OnClose.InvokeAsync();

    private Task OnWindowVisibleChanged(bool visible)
    {
        if (!visible)
            return Close();

        return Task.CompletedTask;
    }

    private static List<CombinedTimelineRow> CombineTimelineRows(IEnumerable<IISLogViewer.Services.TimelineEvent> orderedEvents)
    {
        var result = new List<CombinedTimelineRow>();

        foreach (var e in orderedEvents)
        {
            var action = string.Equals(e.EventType, "Popup", StringComparison.OrdinalIgnoreCase) &&
                         !string.IsNullOrWhiteSpace(e.PopupName) &&
                         e.PopupName != "-"
                ? e.PopupName
                : e.Action;

            if (result.Count == 0 || !string.Equals(result[^1].Action, action, StringComparison.OrdinalIgnoreCase))
            {
                result.Add(new CombinedTimelineRow
                {
                    TimestampLocal = e.TimestampLocal,
                    Action = action,
                    EventType = e.EventType,
                    StatusLabel = e.StatusCode > 0 ? e.StatusCode.ToString() : "-",
                    DurationMs = Math.Max(0, e.DurationMs),
                    Count = 1
                });
                continue;
            }

            var current = result[^1];
            current.Count++;
            current.DurationMs += Math.Max(0, e.DurationMs);
            if (!string.Equals(current.EventType, e.EventType, StringComparison.OrdinalIgnoreCase))
                current.EventType = "Mixed";

            var nextStatus = e.StatusCode > 0 ? e.StatusCode.ToString() : "-";
            if (!string.Equals(current.StatusLabel, nextStatus, StringComparison.OrdinalIgnoreCase))
                current.StatusLabel = "Mixed";
        }

        return result;
    }

    private static string FormatPageAction(string action, string tabName, string moduleName)
    {
        // Split stem and query string
        var parts = action.Split('?');
        var stem = parts[0];
        var queryString = parts.Length > 1 ? parts[1] : "";

        // Filter out TabID and ModuleID from query string
        var filteredParams = string.IsNullOrWhiteSpace(queryString)
            ? string.Empty
            : string.Join("&", queryString
                .Split('&')
                .Where(p => !p.StartsWith("TabID=", StringComparison.OrdinalIgnoreCase) &&
                           !p.StartsWith("ModuleID=", StringComparison.OrdinalIgnoreCase)));

        // Build page reference with optional query string
        var pageRef = string.IsNullOrWhiteSpace(filteredParams)
            ? stem
            : $"{stem}?{filteredParams}";

        // Add Tab/Module context
        var contextParts = new List<string>();
        if (!string.IsNullOrWhiteSpace(tabName) && tabName != "-")
            contextParts.Add(tabName);
        if (!string.IsNullOrWhiteSpace(moduleName) && moduleName != "-")
            contextParts.Add(moduleName);

        return contextParts.Count == 0
            ? pageRef
            : $"{pageRef} ({string.Join(", ", contextParts)})";
    }

    private sealed class CombinedTimelineRow
    {
        public DateTime TimestampLocal { get; set; }
        public string Action { get; set; } = "";
        public string EventType { get; set; } = "Page";
        public string StatusLabel { get; set; } = "-";
        public int DurationMs { get; set; }
        public int Count { get; set; }
    }

    private sealed record ItemHitRow(string Item, int Hits);
    private sealed record HourHitRow(string HourLabel, int Hits);
    private sealed record PeakHourInfo(string HourLabel, int Hits, string PercentageLabel);
    private sealed record WeekdayRow(string DayLabel, string HitsLabel, string PercentLabel);
    private sealed record TimelineDateOption(string Text, string Value);
    private sealed record UserTimelineRow(
        string TimeLabel,
        string Action,
        string EventType,
        string StatusLabel,
        string DurationLabel);
}
