@if (IsOpen)
{
    <TelerikWindow Width="900px"
                   Height="620px"
                   Visible="@IsOpen"
                   Modal="true"
                   Draggable="true"
                   Resizable="true"
                   Class="popup-window popup-window--hourly">
        <WindowTitle>
            Hourly Details - @SelectedHourLabel:00:00
        </WindowTitle>
        <WindowActions>
            <WindowAction Name="Close" />
        </WindowActions>
        <WindowContent>
            <TelerikTabStrip Class="popup-tabs">
                        <TabStripTab Title="🔥 Top Pages">
                            @if (!TopPagesRows.Any())
                            {
                                <div class="text-muted small">No page hits for this hour.</div>
                            }
                            else
                            {
                                <div class="hourly-section__content">
                                    <TelerikGrid Data="@TopPagesRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Page" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
                        <TabStripTab Title="📄 Top Documents">
                            @if (!TopDocumentsRows.Any())
                            {
                                <div class="text-muted small">No document hits for this hour.</div>
                            }
                            else
                            {
                                <div class="hourly-section__content">
                                    <TelerikGrid Data="@TopDocumentsRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Document" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
                        <TabStripTab Title="🪟 Top Popups">
                            @if (!TopPopupsRows.Any())
                            {
                                <div class="text-muted small">No popup hits for this hour.</div>
                            }
                            else
                            {
                                <div class="hourly-section__content">
                                    <TelerikGrid Data="@TopPopupsRows" Pageable="true" PageSize="8" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                                        <GridColumns>
                                            <GridColumn Field="@nameof(ItemHitRow.Item)" Title="Popup" />
                                            <GridColumn Field="@nameof(ItemHitRow.Hits)" Title="Hits" Width="110px">
                                                <Template Context="itemObj">
                                                    @{ var row = (ItemHitRow)itemObj; }
                                                    <div class="text-start">@row.Hits.ToString("N0")</div>
                                                </Template>
                                            </GridColumn>
                                        </GridColumns>
                                    </TelerikGrid>
                                </div>
                            }
                        </TabStripTab>
            </TelerikTabStrip>

        </WindowContent>
    </TelerikWindow>
}

<style>
    .popup-window {
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 22px 50px rgba(0, 0, 0, 0.18);
    }

    .popup-window :is(.k-window-titlebar, .k-dialog-titlebar) {
        background: linear-gradient(120deg, var(--kendo-color-primary, #0d6efd), color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 40%, #0b1324));
        color: #fff;
        font-weight: 700;
        letter-spacing: 0.01em;
    }

    .popup-window .k-window-content {
        background: color-mix(in srgb, var(--kendo-color-surface, #fff) 88%, var(--kendo-color-app-surface, #f5f5f5));
        padding: 0.35rem;
    }

    .popup-tabs {
        margin-top: 0.1rem;
    }

    .hourly-section__content {
        padding: 0.45rem 0.1rem 0.2rem;
    }
</style>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public int SelectedHour { get; set; }

    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private const int MaxRows = 12;

    private string SelectedHourLabel => SelectedHour.ToString("D2");

    private List<ItemHitRow> TopPagesRows => MapRows(GetTopByHour(ReportData?.HourlyPageHits, SelectedHour));
    private List<ItemHitRow> TopDocumentsRows => MapRows(GetTopByHour(ReportData?.HourlyDocumentHits, SelectedHour));
    private List<ItemHitRow> TopPopupsRows => MapRows(GetTopByHour(ReportData?.HourlyPopupHits, SelectedHour));

    private static IEnumerable<KeyValuePair<string, int>> GetTopByHour(
        Dictionary<int, Dictionary<string, int>>? source,
        int hour)
    {
        if (source == null || !source.TryGetValue(hour, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<string, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Take(MaxRows);
    }

    private static List<ItemHitRow> MapRows(IEnumerable<KeyValuePair<string, int>> source) =>
        source.Select(x => new ItemHitRow(x.Key, x.Value)).ToList();

    private Task Close() => OnClose.InvokeAsync();

    private sealed record ItemHitRow(string Item, int Hits);
}
