@inject IISLogViewer.Services.LogParserService LogParserService

<div class="report-tabs">
    <TelerikTabStrip @bind-ActiveTabIndex="ActiveTabIndex" Class="report-tabs__strip">
        <TabStripTab Title="@GetTabTitle(TabName.Pages)" />
        <TabStripTab Title="@GetTabTitle(TabName.Documents)" />
        <TabStripTab Title="@GetTabTitle(TabName.Popups)" />
        <TabStripTab Title="@GetTabTitle(TabName.Users)" />
        <TabStripTab Title="@GetTabTitle(TabName.HourlyHits)" />
        <TabStripTab Title="@GetTabTitle(TabName.Weekdays)" />
        <TabStripTab Title="@GetTabTitle(TabName.StatusCodes)" />
        <TabStripTab Title="@GetTabTitle(TabName.IPs)" />
        <TabStripTab Title="@GetTabTitle(TabName.Errors)" />
        <TabStripTab Title="@GetTabTitle(TabName.SlowPages)" />
    </TelerikTabStrip>

    <div class="report-tabs__content" role="tabpanel">
        @if (ActiveTab == TabName.Pages)
        {
            <div class="grid-toolbar">
                <div>
                    <h3>Top Pages</h3>
                    <div class="toolbar-subtle">Includes entry pages and most common next page transitions.</div>
                </div>
                <TelerikTextBox Value="@_searchPages"
                                ValueChanged="@(v => _searchPages = v ?? string.Empty)"
                                Placeholder="Search pages"
                                Width="260px"
                                Size="@ThemeConstants.TextBox.Size.Small"
                                FillMode="@ThemeConstants.TextBox.FillMode.Outline"
                                DebounceDelay="250"
                                ShowClearButton="true" />
            </div>

            <div class="report-note">
                <strong>Hits:</strong> total requests for the page. |
                <strong>Entry Hits:</strong> times this page was the first action in a user session window. |
                <strong>Top Next Page:</strong> the most common page users visited immediately after this page.
            </div>

            @if (!FilteredTopPageRows.Any())
            {
                <div class="empty-state">No page data found.</div>
            }
            else
            {
                <TelerikGrid Data="@FilteredTopPageRows"
                             Pageable="true"
                             @bind-PageSize="_pageSize"
                             Sortable="false"
                             Size="@ThemeConstants.Grid.Size.Small">
                    <GridColumns>
                        <GridColumn Field="@nameof(TopPageInsightRow.Page)" Title="Page" />
                        <GridColumn Field="@nameof(TopPageInsightRow.HitsLabel)" Title="Hits" Width="120px">
                            <Template Context="itemObj">
                                @{ var row = (TopPageInsightRow)itemObj; }
                                <div class="text-start">@row.HitsLabel</div>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(TopPageInsightRow.EntryHitsLabel)" Title="Entry Hits" Width="130px">
                            <Template Context="itemObj">
                                @{ var row = (TopPageInsightRow)itemObj; }
                                <div class="text-start">@row.EntryHitsLabel</div>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(TopPageInsightRow.TopNextPage)" Title="Top Next Page" Width="360px">
                            <Template Context="itemObj">
                                @{ var row = (TopPageInsightRow)itemObj; }
                                @if (row.HasFlowDetails)
                                {
                                    <a href="#"
                                       class="next-page-link"
                                       @onclick:preventDefault="true"
                                       @onclick="() => OpenNextPageFlowPopup(row.Page)">
                                        @row.TopNextPage
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">@row.TopNextPage</span>
                                }
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </TelerikGrid>
            }

            @if (_showNextPageFlowPopup)
            {
                <TelerikWindow Width="880px"
                               Height="560px"
                               Visible="@_showNextPageFlowPopup"
                               Modal="true"
                               Draggable="true"
                               Resizable="true"
                               Class="popup-window popup-window--flow">
                    <WindowTitle>
                        Next Page Flow - @_selectedFlowPage
                    </WindowTitle>
                    <WindowActions>
                        <WindowAction Name="Close" />
                    </WindowActions>
                    <WindowContent>
                        @if (!SelectedNextPageFlowRows.Any())
                        {
                            <div class="empty-state">No next-page transitions found for this page.</div>
                        }
                        else
                        {
                            <TelerikGrid Data="@SelectedNextPageFlowRows"
                                         Pageable="true"
                                         @bind-PageSize="_pageSize"
                                         Sortable="false"
                                         Size="@ThemeConstants.Grid.Size.Small">
                                <GridColumns>
                                    <GridColumn Field="@nameof(NextPageFlowRow.NextPage)" Title="Next Page" />
                                    <GridColumn Field="@nameof(NextPageFlowRow.CountLabel)" Title="Transitions" Width="140px">
                                        <Template Context="itemObj">
                                            @{ var row = (NextPageFlowRow)itemObj; }
                                            <div class="text-start">@row.CountLabel</div>
                                        </Template>
                                    </GridColumn>
                                </GridColumns>
                            </TelerikGrid>
                        }
                    </WindowContent>
                </TelerikWindow>
            }
        }
        else if (ActiveTab == TabName.IPs)
        {
            <LabelValueSection Title="IP Addresses"
                               Placeholder="Search IPs"
                               LabelHeader="IP Address"
                               ValueHeader="Hits"
                               SearchValue="@_searchIPs"
                               SearchValueChanged="@(v => _searchIPs = v)"
                               Rows="@FilteredIpRows" />
        }
        else if (ActiveTab == TabName.Errors)
        {
            <LabelValueSection Title="Error Pages"
                               Placeholder="Search errors"
                               LabelHeader="Page"
                               ValueHeader="Hits"
                               SearchValue="@_searchErrors"
                               SearchValueChanged="@(v => _searchErrors = v)"
                               Rows="@FilteredErrorRows" />
        }
        else if (ActiveTab == TabName.Documents)
        {
            <div class="grid-toolbar">
                <div><h3>Documents</h3></div>
                  <TelerikTextBox Value="@_searchDocs"
                            ValueChanged="OnDocsSearchChanged"
                            Placeholder="Search documents"
                            Width="260px"
                            Size="@ThemeConstants.TextBox.Size.Small"
                            FillMode="@ThemeConstants.TextBox.FillMode.Outline"
                            DebounceDelay="250"
                            ShowClearButton="true" />
            </div>

            @if (!FilteredDocumentRows.Any())
            {
                <div class="empty-state">No document downloads found.</div>
            }
            else
            {
                <TelerikGrid Data="@SortedDocuments"
                             Pageable="true"
                             @bind-PageSize="_pageSize"
                             Sortable="false"
                             Size="@ThemeConstants.Grid.Size.Small">
                    <GridColumns>
                        <GridColumn Field="@nameof(DocumentRow.File)">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleDocSort(nameof(DocumentRow.File))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">File @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.File))</TelerikButton>
                            </HeaderTemplate>
                        </GridColumn>
                        <GridColumn Field="@nameof(DocumentRow.TypeLabel)" Width="90px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleDocSort(nameof(DocumentRow.TypeLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Type @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.TypeLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (DocumentRow)itemObj; }
                                <span class="text-muted">@row.TypeLabel</span>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(DocumentRow.DownloadsLabel)" Width="120px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleDocSort(nameof(DocumentRow.DownloadsLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Downloads @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.DownloadsLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (DocumentRow)itemObj; }
                                <div class="text-start">@row.DownloadsLabel</div>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(DocumentRow.AvgTimeLabel)" Width="120px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleDocSort(nameof(DocumentRow.AvgTimeLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Avg Time @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.AvgTimeLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (DocumentRow)itemObj; }
                                <div class="text-start">@row.AvgTimeLabel</div>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </TelerikGrid>

            }
        }
        else if (ActiveTab == TabName.Popups)
        {
            <LabelValueSection Title="Popups"
                               Placeholder="Search popups"
                               LabelHeader="Type"
                               ValueHeader="Hits"
                               SearchValue="@_searchPopups"
                               SearchValueChanged="@(v => _searchPopups = v)"
                               Rows="@FilteredPopupRows" />
        }
        else if (ActiveTab == TabName.StatusCodes)
        {
            <div class="grid-toolbar">
                <div><h3>Status Codes</h3></div>
                  <TelerikTextBox Value="@_searchStatus"
                            ValueChanged="OnStatusSearchChanged"
                            Placeholder="Search status"
                            Width="260px"
                            Size="@ThemeConstants.TextBox.Size.Small"
                            FillMode="@ThemeConstants.TextBox.FillMode.Outline"
                            DebounceDelay="250"
                            ShowClearButton="true" />
            </div>

            @if (!FilteredStatusRows.Any())
            {
                <div class="empty-state">No status codes found.</div>
            }
            else
            {
                <TelerikGrid Data="@SortedStatuses"
                             Pageable="true"
                             @bind-PageSize="_pageSize"
                             Sortable="false"
                             Size="@ThemeConstants.Grid.Size.Small">
                    <GridColumns>
                        <GridColumn Field="@nameof(StatusRow.StatusDisplay)" Width="220px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleStatusSort(nameof(StatusRow.StatusDisplay))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Status @SortGlyph(_statusSortField, _statusSortDesc, nameof(StatusRow.StatusDisplay))</TelerikButton>
                            </HeaderTemplate>
                        </GridColumn>
                        <GridColumn Field="@nameof(StatusRow.CountLabel)" Width="140px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleStatusSort(nameof(StatusRow.CountLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Count @SortGlyph(_statusSortField, _statusSortDesc, nameof(StatusRow.CountLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (StatusRow)itemObj; }
                                <div class="text-start">@row.CountLabel</div>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </TelerikGrid>

            }
        }
        else if (ActiveTab == TabName.SlowPages)
        {
            <div class="grid-toolbar">
                <div><h3>Slow Pages</h3></div>
                  <TelerikTextBox Value="@_searchSlow"
                            ValueChanged="OnSlowSearchChanged"
                            Placeholder="Search slow pages"
                            Width="260px"
                            Size="@ThemeConstants.TextBox.Size.Small"
                            FillMode="@ThemeConstants.TextBox.FillMode.Outline"
                            DebounceDelay="250"
                            ShowClearButton="true" />
            </div>

            @if (!FilteredSlowPageRows.Any())
            {
                <div class="empty-state">No slow pages found.</div>
            }
            else
            {
                <TelerikGrid Data="@SortedSlowPages"
                             Pageable="true"
                             @bind-PageSize="_pageSize"
                             Sortable="false"
                             Size="@ThemeConstants.Grid.Size.Small">
                    <GridColumns>
                        <GridColumn Field="@nameof(SlowPageRow.Page)">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleSlowSort(nameof(SlowPageRow.Page))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Page @SortGlyph(_slowSortField, _slowSortDesc, nameof(SlowPageRow.Page))</TelerikButton>
                            </HeaderTemplate>
                        </GridColumn>
                        <GridColumn Field="@nameof(SlowPageRow.AvgTimeLabel)" Width="160px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleSlowSort(nameof(SlowPageRow.AvgTimeLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Avg Time (ms) @SortGlyph(_slowSortField, _slowSortDesc, nameof(SlowPageRow.AvgTimeLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (SlowPageRow)itemObj; }
                                <div class="text-start">@row.AvgTimeLabel</div>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </TelerikGrid>

            }
        }
        else if (ActiveTab == TabName.HourlyHits)
        {
            <div class="grid-toolbar">
                <div>
                    <h3>Hourly Hits</h3>
                    <div class="toolbar-subtle">Timezone: @LogParserService.TargetTimeZoneId</div>
                </div>
                  <TelerikTextBox Value="@_searchHours"
                            ValueChanged="OnHoursSearchChanged"
                            Placeholder="Search hours"
                            Width="260px"
                            Size="@ThemeConstants.TextBox.Size.Small"
                            FillMode="@ThemeConstants.TextBox.FillMode.Outline"
                            DebounceDelay="250"
                            ShowClearButton="true" />
            </div>

            @if (!FilteredHourRows.Any())
            {
                <div class="empty-state">No hourly data found.</div>
            }
            else
            {
                <TelerikGrid Data="@SortedHours"
                             Pageable="true"
                             @bind-PageSize="_pageSize"
                             Sortable="false"
                             Size="@ThemeConstants.Grid.Size.Small">
                    <GridColumns>
                        <GridColumn Field="@nameof(HourRow.HourLabel)" Width="120px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleHourSort(nameof(HourRow.HourLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Hour @SortGlyph(_hourSortField, _hourSortDesc, nameof(HourRow.HourLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (HourRow)itemObj; }
                                <a href="#"
                                   class="hour-link"
                                   @onclick:preventDefault="true"
                                   @onclick="() => OpenHourlyPopup(row.HourLabel)">
                                    @row.HourLabel
                                </a>
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(HourRow.HitsLabel)" Width="140px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleHourSort(nameof(HourRow.HitsLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Hits @SortGlyph(_hourSortField, _hourSortDesc, nameof(HourRow.HitsLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (HourRow)itemObj; }
                                <div class="text-start">@row.HitsLabel</div>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </TelerikGrid>

            }

            <HourlyHitsDetailPopup IsOpen="@_showHourlyDetailsPopup"
                                   SelectedHour="@_selectedHour"
                                   ReportData="@ReportData"
                                   OnClose="CloseHourlyPopup" />
        }
        else if (ActiveTab == TabName.Weekdays)
        {
            <div class="grid-toolbar">
                <div><h3>Day Of Week</h3></div>
            </div>

            <TelerikGrid Data="@WeekdayRows" Pageable="true" @bind-PageSize="_pageSize" Sortable="false" Size="@ThemeConstants.Grid.Size.Small">
                <GridColumns>
                    <GridColumn Field="@nameof(WeekdayListRow.DayLabel)" Title="Day">
                        <Template Context="itemObj">
                            @{ var row = (WeekdayListRow)itemObj; }
                            <a href="#"
                               class="weekday-link"
                               @onclick:preventDefault="true"
                               @onclick="() => OpenWeekdayPopup(row.DayIndex)">
                                @row.DayLabel
                            </a>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(WeekdayListRow.HitsLabel)" Title="Hits" Width="140px">
                        <Template Context="itemObj">
                            @{ var row = (WeekdayListRow)itemObj; }
                            <div class="text-start">@row.HitsLabel</div>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </TelerikGrid>

            <WeekdayDetailPopup IsOpen="@_showWeekdayDetailsPopup"
                                SelectedWeekday="@_selectedWeekday"
                                ReportData="@ReportData"
                                OnClose="CloseWeekdayPopup" />
        }
        else if (ActiveTab == TabName.Users)
        {
            <div class="grid-toolbar">
                <div><h3>Users</h3></div>
                  <TelerikTextBox Value="@_searchUsers"
                            ValueChanged="OnUsersSearchChanged"
                            Placeholder="Search users"
                            Width="260px"
                            Size="@ThemeConstants.TextBox.Size.Small"
                            FillMode="@ThemeConstants.TextBox.FillMode.Outline"
                            DebounceDelay="250"
                            ShowClearButton="true" />
            </div>

            @if (!FilteredUserRows.Any())
            {
                <div class="empty-state">No user data found. Enable cs-username in IIS log fields.</div>
            }
            else
            {
                <TelerikGrid Data="@SortedUsers"
                             Pageable="true"
                             @bind-PageSize="_pageSize"
                             Sortable="false"
                             Size="@ThemeConstants.Grid.Size.Small">
                    <GridColumns>
                        <GridColumn Field="@nameof(UserRow.DisplayName)">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleUserSort(nameof(UserRow.DisplayName))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Name @SortGlyph(_userSortField, _userSortDesc, nameof(UserRow.DisplayName))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (UserRow)itemObj; }
                                <a href="#"
                                   class="user-link"
                                   @onclick:preventDefault="true"
                                   @onclick="() => OpenUserPopup(row.UserName)">
                                    @row.DisplayName
                                </a>
                                @if (!string.IsNullOrWhiteSpace(row.Email))
                                {
                                    <div class="toolbar-subtle">@row.Email</div>
                                }
                            </Template>
                        </GridColumn>
                        <GridColumn Field="@nameof(UserRow.Department)" Width="180px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleUserSort(nameof(UserRow.Department))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Department @SortGlyph(_userSortField, _userSortDesc, nameof(UserRow.Department))</TelerikButton>
                            </HeaderTemplate>
                        </GridColumn>
                        <GridColumn Field="@nameof(UserRow.HitsLabel)" Width="140px">
                            <HeaderTemplate>
                                <TelerikButton OnClick="() => ToggleUserSort(nameof(UserRow.HitsLabel))" FillMode="@ThemeConstants.Button.FillMode.Flat" Size="@ThemeConstants.Button.Size.Small">Hits @SortGlyph(_userSortField, _userSortDesc, nameof(UserRow.HitsLabel))</TelerikButton>
                            </HeaderTemplate>
                            <Template Context="itemObj">
                                @{ var row = (UserRow)itemObj; }
                                <div class="text-start">@row.HitsLabel</div>
                            </Template>
                        </GridColumn>
                    </GridColumns>
                </TelerikGrid>

            }

            <UserHitsDetailPopup IsOpen="@_showUserDetailsPopup"
                                 SelectedUser="@_selectedUser"
                                 SelectedUserDisplayName="@_selectedUserDisplayName"
                                 SelectedDays="@SelectedDays"
                                 ReportData="@ReportData"
                                 OnClose="CloseUserPopup" />
        }
    </div>
</div>

<style>
    .report-tabs {
        display: block;
    }

    .report-tabs__strip {
        margin-bottom: 10px;
    }

    .report-tabs__strip .k-tabstrip-content,
    .report-tabs__strip .k-content.k-active {
        display: none;
        padding: 0;
        margin: 0;
        border: 0;
        min-height: 0;
    }

    .report-tabs__content {
        min-height: 0;
    }

    .grid-toolbar {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 0.65rem;
        min-height: 40px;
    }

    .grid-toolbar h3 {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--kendo-color-on-surface, inherit) !important;
        opacity: 1 !important;
    }

    .toolbar-subtle {
        margin-top: 0.1rem;
        font-size: 0.76rem;
        color: var(--kendo-color-subtle, #666);
    }

    .empty-state {
        padding: 0.75rem 0.2rem 0.35rem;
        color: var(--kendo-color-subtle, #666);
    }

    .report-note {
        margin: 0.2rem 0 0.65rem;
        padding: 0.45rem 0.6rem;
        border: 1px solid var(--kendo-color-border, #d4d4d4);
        border-radius: 8px;
        background: color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 4%, #fff);
        font-size: 0.78rem;
        color: var(--kendo-color-subtle, #666);
    }

    .weekday-link,
    .hour-link,
    .user-link,
    .next-page-link {
        color: var(--kendo-color-primary, #0d6efd) !important;
        text-decoration: none;
        cursor: pointer;
        font-weight: 600;
        display: inline-block;
        padding: 0.05rem 0;
    }

    .weekday-link:hover,
    .hour-link:hover,
    .user-link:hover,
    .next-page-link:hover {
        color: color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 85%, #000) !important;
        text-decoration: underline;
    }

    .weekday-link:focus-visible,
    .hour-link:focus-visible,
    .user-link:focus-visible,
    .next-page-link:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--kendo-color-primary, #0d6efd) 45%, transparent);
        outline-offset: 2px;
        border-radius: 4px;
    }

    @@media (max-width: 720px) {
        .grid-toolbar {
            align-items: stretch;
            flex-direction: column;
        }
    }
</style>

@code {
    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    [Parameter]
    public IEnumerable<DateTime>? SelectedDays { get; set; }

    private enum TabName
    {
        Pages,
        IPs,
        Errors,
        Documents,
        Popups,
        StatusCodes,
        SlowPages,
        HourlyHits,
        Weekdays,
        Users
    }

    private static readonly IReadOnlyList<TabName> Tabs = new[]
    {
        TabName.Pages,
        TabName.Documents,
        TabName.Popups,
        TabName.Users,
        TabName.HourlyHits,
        TabName.Weekdays,
        TabName.StatusCodes,
        TabName.IPs,
        TabName.Errors,
        TabName.SlowPages,
    };

    private int _activeTabIndex;

    private int ActiveTabIndex
    {
        get => _activeTabIndex;
        set
        {
            if (_activeTabIndex == value)
                return;

            _activeTabIndex = value;
            CloseAllPopups();
        }
    }

    private TabName ActiveTab =>
        ActiveTabIndex >= 0 && ActiveTabIndex < Tabs.Count ? Tabs[ActiveTabIndex] : TabName.Pages;

    private string GetTabTitle(TabName tab)
    {
        var (name, count) = tab switch
        {
            TabName.Pages => ("🔥 Pages", ReportData?.PageHits?.Count ?? 0),
            TabName.IPs => ("🌐 IPs", ReportData?.TopIPs?.Count ?? 0),
            TabName.Errors => ("❌ Errors", ReportData?.ErrorPages?.Count ?? 0),
            TabName.Documents => ("📄 Documents", ReportData?.DocumentHits?.Count ?? 0),
            TabName.Popups => ("🪟 Popups", ReportData?.PopupHits?.Count ?? 0),
            TabName.StatusCodes => ("📊 Status Codes", ReportData?.StatusCodes?.Count ?? 0),
            TabName.SlowPages => ("🐢 Slow Pages", ReportData?.SlowPages?.Count ?? 0),
            TabName.HourlyHits => ("⏰ Hourly Hits", ReportData?.HourlyHits?.Count ?? 0),
            TabName.Weekdays => ("📅 Day Of Week", 7),
            TabName.Users => ("👤 Users", ReportData?.UserHits?.Count ?? 0),
            _ => (tab.ToString(), 0)
        };

        return $"{name} ({count:N0})";
    }

    // Search strings for each distinct tab
    private string _searchPages = "";
    private string _searchIPs = "";
    private string _searchErrors = "";
    private string _searchDocs = "";
    private string _searchPopups = "";
    private string _searchStatus = "";
    private string _searchSlow = "";
    private string _searchHours = "";
    private string _searchUsers = "";

    private IEnumerable<TopPageInsightRow> FilteredTopPageRows =>
        BuildTopPageInsights()
            .Where(row => FilterCore($"{row.Page} {row.TopNextPage}", _searchPages));

    private IEnumerable<LabelValueRow> FilteredIpRows => FilterLabelValueRows(ReportData?.TopIPs, _searchIPs);
    private IEnumerable<LabelValueRow> FilteredErrorRows => FilterLabelValueRows(ReportData?.ErrorPages, _searchErrors);
    private IEnumerable<LabelValueRow> FilteredPopupRows => FilterLabelValueRows(ReportData?.PopupHits, _searchPopups);
    private IEnumerable<DocumentRow> FilteredDocumentRows => (ReportData?.DocumentHits ?? [])
        .Select(item =>
        {
            var ext = Path.GetExtension(item.Key).ToLowerInvariant();
            var avgMs = ReportData?.DocumentAvgTime.GetValueOrDefault(item.Key) ?? 0;
            return new DocumentRow(
                item.Key,
                string.IsNullOrWhiteSpace(ext) ? "unknown" : ext.TrimStart('.'),
                item.Value.ToString("N0"),
                $"{avgMs:N0} ms");
        })
        .Where(item => FilterCore($"{item.File} {item.TypeLabel}", _searchDocs))
        .OrderByDescending(item => int.Parse(item.DownloadsLabel.Replace(",", string.Empty)));

    private IEnumerable<StatusRow> FilteredStatusRows => (ReportData?.StatusCodes ?? [])
        .OrderByDescending(item => item.Value)
        .Select(item => new StatusRow(item.Key, IISLogViewer.Services.LogParserService.GetStatusDisplay(item.Key), item.Value.ToString("N0")))
        .Where(item => FilterCore(item.StatusDisplay, _searchStatus));

    private IEnumerable<SlowPageRow> FilteredSlowPageRows => (ReportData?.SlowPages ?? [])
        .Select(item => new SlowPageRow(item.Key, $"{item.Value:N0} ms"))
        .Where(item => FilterCore(item.Page, _searchSlow))
        .OrderByDescending(item => ParseMetric(item.AvgTimeLabel));

    private IEnumerable<HourRow> FilteredHourRows => (ReportData?.HourlyHits ?? [])
        .OrderByDescending(item => item.Value)
        .Select(item => new HourRow(item.Key.ToString("D2"), item.Value.ToString("N0")))
        .Where(item => FilterCore(item.HourLabel, _searchHours));

    private IEnumerable<UserRow> FilteredUserRows => (ReportData?.UserHits ?? [])
        .Select(item => BuildUserRow(item.Key, item.Value))
        .Where(item => FilterCore($"{item.UserName} {item.DisplayName} {item.Department} {item.Email}", _searchUsers));

    private IEnumerable<WeekdayListRow> WeekdayRows => BuildWeekdayRows();

