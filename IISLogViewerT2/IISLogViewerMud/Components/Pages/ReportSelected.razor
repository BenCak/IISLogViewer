@page "/report"
@rendermode InteractiveServer
@inject IISLogViewer.Services.LogParserService LogParser
@inject IISLogViewer.Services.SelectionState SelectionState
@implements IDisposable

<MudText Typo="Typo.h5" Class="mb-4">@ReportTitle</MudText>

@if (!SelectionState.SelectedDays.Any())
{
    <MudAlert Severity="Severity.Info">
        Select dates from the tree on the left to generate a report.
    </MudAlert>
}
else if (CurrentReport == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4"/>
    <MudText>Loading report...</MudText>
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="text-align:center">
                <MudText Typo="Typo.h4" Color="Color.Primary">@CurrentReport.TotalHits.ToString("N0")</MudText>
                <MudText Typo="Typo.body2">Total Hits</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="text-align:center">
                <MudText Typo="Typo.h4" Color="Color.Success">@SuccessCount.ToString("N0")</MudText>
                <MudText Typo="Typo.body2">Successful (2xx/3xx)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="text-align:center">
                <MudText Typo="Typo.h4" Color="Color.Warning">@ClientErrorCount.ToString("N0")</MudText>
                <MudText Typo="Typo.body2">Client Errors (4xx)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2" Style="text-align:center">
                <MudText Typo="Typo.h4" Color="Color.Error">@ServerErrorCount.ToString("N0")</MudText>
                <MudText Typo="Typo.body2">Server Errors (5xx)</MudText>
            </MudPaper>
        </MudItem>

        <!-- Tabbed Data Sections -->
        <MudItem xs="12">
            <MudPaper Elevation="2">
                <Report ReportData="CurrentReport" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private IISLogViewer.Services.LogReport? CurrentReport;
    private string ReportTitle = "Report";
    private int SuccessCount;
    private int ClientErrorCount;
    private int ServerErrorCount;

    protected override async Task OnInitializedAsync()
    {
        SelectionState.OnChange += OnSelectionChanged;
        await LoadReport();
    }

    private async void OnSelectionChanged()
    {
        await LoadReport();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadReport()
    {
        CurrentReport = null; // show loading state

        if (!SelectionState.SelectedDays.Any())
        {
            ReportTitle = "Report";
            return;
        }

        var days = SelectionState.SelectedDays.ToList();

        ReportTitle = days.Count == 1
            ? $"Report for {days[0]:dddd, dd MMMM yyyy}"
            : $"Report for {days.Count} selected days ({days.Min():dd MMM yyyy} — {days.Max():dd MMM yyyy})";

        if (days.Count == 1)
        {
            CurrentReport = await LogParser.ParseFile(days[0]);
        }
        else
        {
            CurrentReport = await LogParser.ParseDates(days);
        }

        if (CurrentReport != null)
        {
            SuccessCount = CurrentReport.StatusCodes
                .Where(s => s.Key >= 200 && s.Key < 400).Sum(s => s.Value);
            ClientErrorCount = CurrentReport.StatusCodes
                .Where(s => s.Key >= 400 && s.Key < 500).Sum(s => s.Value);
            ServerErrorCount = CurrentReport.StatusCodes
                .Where(s => s.Key >= 500).Sum(s => s.Value);
        }
    }

    public void Dispose()
    {
        SelectionState.OnChange -= OnSelectionChanged;
    }
}