{
  "name": "IISLogViewer Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolution": "IISLogViewer.sln"
      }
    }
  },
  "forwardPorts": [5000],
  "postCreateCommand": "dotnet restore",
  "mounts": [
    "source=${localWorkspaceFolder}/LogFiles,target=/workspaces/IISLogViewer/LogFiles,type=bind"
  ],
  "remoteUser": "vscode"
}
