@inherits LayoutComponentBase
@rendermode InteractiveServer

<TelerikRootComponent>
    <div class="app-shell @_selectedTheme.CssClass">
        <header class="app-shell__header">
            <div>
                <div class="app-shell__title">IIS Log Viewer</div>
                <div class="app-shell__subtitle">W3SVC2 analytics workspace</div>
            </div>

            <div class="app-shell__theme-picker">
                <label class="app-shell__label" for="theme-selector">Theme</label>
                <TelerikDropDownList Id="theme-selector"
                                     Data="@ThemeNames"
                                     Value="@_selectedTheme.Name"
                                     ValueChanged="@( (string value) => OnThemeChanged(value) )"
                                     Width="200px"
                                     Size="@ThemeConstants.DropDownList.Size.Small"
                                     FillMode="@ThemeConstants.DropDownList.FillMode.Outline" />
            </div>
        </header>

        <div class="app-shell__body">
            <aside class="app-shell__sidebar">
                <div class="app-shell__sidebar-title">Log Files</div>
                <NavMenu />
            </aside>

            <main class="app-shell__content">
                @Body
            </main>
        </div>
    </div>
</TelerikRootComponent>

<style>
    .app-shell {
        --shell-bg: #f3f7fb;
        --shell-panel: #ffffff;
        --shell-panel-muted: #eef3f9;
        --shell-border: #d7e0ec;
        --shell-text: #112033;
        --shell-subtle: #5b6b83;
        --shell-primary: #0d6efd;
        --shell-accent: #1f3c88;
        min-height: 100vh;
        background:
            radial-gradient(circle at top right, rgba(13, 110, 253, 0.12), transparent 30%),
            linear-gradient(180deg, #f8fbff 0%, var(--shell-bg) 65%);
        color: var(--shell-text);
    }

    .app-shell.theme-slate {
        --shell-bg: #0f172a;
        --shell-panel: #162033;
        --shell-panel-muted: #0b1220;
        --shell-border: #273449;
        --shell-text: #edf4ff;
        --shell-subtle: #96a7c2;
        --shell-primary: #60a5fa;
        --shell-accent: #1e293b;
    }

    .app-shell.theme-ocean {
        --shell-bg: #071a2f;
        --shell-panel: #0f2945;
        --shell-panel-muted: #092038;
        --shell-border: #234c70;
        --shell-text: #e5f4ff;
        --shell-subtle: #9dc2df;
        --shell-primary: #22d3ee;
        --shell-accent: #0b2239;
    }

    .app-shell.theme-emerald {
        --shell-bg: #06261c;
        --shell-panel: #0d3b2c;
        --shell-panel-muted: #082e22;
        --shell-border: #1d5b45;
        --shell-text: #ebfff6;
        --shell-subtle: #a1d9c1;
        --shell-primary: #34d399;
        --shell-accent: #0a2a1f;
    }

    .app-shell.theme-crimson {
        --shell-bg: #241319;
        --shell-panel: #3a1c25;
        --shell-panel-muted: #2b131c;
        --shell-border: #6f3243;
        --shell-text: #fff1f4;
        --shell-subtle: #efb0bd;
        --shell-primary: #fb7185;
        --shell-accent: #2d141d;
    }

    .app-shell__header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        padding: 1.5rem 1.75rem 1rem;
        border-bottom: 1px solid var(--shell-border);
        background: linear-gradient(135deg, var(--shell-accent), var(--shell-panel));
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(12px);
    }

    .app-shell__title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .app-shell__subtitle,
    .app-shell__label {
        color: var(--shell-subtle);
        font-size: 0.85rem;
    }

    .app-shell__theme-picker {
        min-width: 220px;
    }

    .app-shell__body {
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        gap: 1.25rem;
        padding: 1.25rem;
    }

    .app-shell__sidebar,
    .app-shell__content {
        background: var(--shell-panel);
        border: 1px solid var(--shell-border);
        border-radius: 20px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .app-shell__sidebar {
        padding: 1rem 0.75rem;
        position: sticky;
        top: 6.25rem;
        max-height: calc(100vh - 7.5rem);
        overflow: auto;
    }

    .app-shell__sidebar-title {
        padding: 0 0.5rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--shell-subtle);
    }

    .app-shell__content {
        padding: 1.25rem;
    }

    .app-shell :is(h1, h2, h3, h4, h5, h6, p, span, div, strong, label, a) {
        color: inherit;
    }

    @@media (max-width: 960px) {
        .app-shell__body {
            grid-template-columns: 1fr;
        }

        .app-shell__sidebar {
            position: static;
            max-height: none;
        }

        .app-shell__header {
            align-items: start;
            flex-direction: column;
        }
    }
</style>

@code {
    private ThemeOption _selectedTheme = ThemeOptions[0];

    private static IReadOnlyList<string> ThemeNames => ThemeOptions.Select(x => x.Name).ToList();

    private static readonly IReadOnlyList<ThemeOption> ThemeOptions = new[]
    {
        new ThemeOption("Light", "theme-light"),
        new ThemeOption("Slate", "theme-slate"),
        new ThemeOption("Ocean", "theme-ocean"),
        new ThemeOption("Emerald", "theme-emerald"),
        new ThemeOption("Crimson", "theme-crimson")
    };

    private void OnThemeChanged(string themeName)
    {
        _selectedTheme = ThemeOptions.FirstOrDefault(x => x.Name == themeName) ?? ThemeOptions[0];
    }

    private sealed record ThemeOption(string Name, string CssClass);
}
