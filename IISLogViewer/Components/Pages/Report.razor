@inject IISLogViewer.Services.LogParserService LogParserService

<div class="report-tabs">
    <div class="report-tabs__bar" role="tablist" aria-label="Report tabs">
        @foreach (var tab in Tabs)
        {
            <button type="button"
                    class="btn btn-sm @(ActiveTab == tab ? "btn-primary" : "btn-outline-primary") report-tabs__tab"
                    role="tab"
                    aria-selected="@(ActiveTab == tab)"
                    @onclick="@(() => ActiveTab = tab)">
                @GetTabTitle(tab)
            </button>
        }
    </div>

    <div class="report-tabs__content" role="tabpanel">
        @if (ActiveTab == TabName.Pages)
        {
            <LabelValueSection Title="All Pages"
                               Placeholder="Search pages"
                               LabelHeader="Page"
                               ValueHeader="Hits"
                               SearchValue="@_searchPages"
                               SearchValueChanged="@(v => _searchPages = v)"
                               Rows="@FilteredPageRows" />
        }
        else if (ActiveTab == TabName.IPs)
        {
            <LabelValueSection Title="IP Addresses"
                               Placeholder="Search IPs"
                               LabelHeader="IP Address"
                               ValueHeader="Hits"
                               SearchValue="@_searchIPs"
                               SearchValueChanged="@(v => _searchIPs = v)"
                               Rows="@FilteredIpRows" />
        }
        else if (ActiveTab == TabName.Errors)
        {
            <LabelValueSection Title="Error Pages"
                               Placeholder="Search errors"
                               LabelHeader="Page"
                               ValueHeader="Hits"
                               SearchValue="@_searchErrors"
                               SearchValueChanged="@(v => _searchErrors = v)"
                               Rows="@FilteredErrorRows" />
        }
        else if (ActiveTab == TabName.Documents)
        {
            <div class="grid-toolbar">
                <div><h3>Documents</h3></div>
                <input class="form-control form-control-sm"
                       style="max-width: 260px;"
                       placeholder="Search documents"
                       value="@_searchDocs"
                       @oninput="@(e => { _searchDocs = e.Value?.ToString() ?? ""; _docPage = 1; })" />
            </div>

            @if (!FilteredDocumentRows.Any())
            {
                <div class="empty-state">No document downloads found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleDocSort(nameof(DocumentRow.File))">File @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.File))</button></th>
                                <th style="width: 90px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleDocSort(nameof(DocumentRow.TypeLabel))">Type @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.TypeLabel))</button></th>
                                <th class="text-end" style="width: 120px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleDocSort(nameof(DocumentRow.DownloadsLabel))">Downloads @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.DownloadsLabel))</button></th>
                                <th class="text-end" style="width: 120px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleDocSort(nameof(DocumentRow.AvgTimeLabel))">Avg Time @SortGlyph(_docSortField, _docSortDesc, nameof(DocumentRow.AvgTimeLabel))</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in PagedDocuments)
                            {
                                <tr>
                                    <td>@r.File</td>
                                    <td class="text-muted">@r.TypeLabel</td>
                                    <td class="text-end">@r.DownloadsLabel</td>
                                    <td class="text-end">@r.AvgTimeLabel</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pager CurrentPage="@_docPage"
                       TotalPages="@DocPageCount"
                       OnPageChanged="@(p => _docPage = p)" />
            }
        }
        else if (ActiveTab == TabName.Popups)
        {
            <LabelValueSection Title="Popups"
                               Placeholder="Search popups"
                               LabelHeader="Type"
                               ValueHeader="Hits"
                               SearchValue="@_searchPopups"
                               SearchValueChanged="@(v => _searchPopups = v)"
                               Rows="@FilteredPopupRows" />
        }
        else if (ActiveTab == TabName.StatusCodes)
        {
            <div class="grid-toolbar">
                <div><h3>Status Codes</h3></div>
                <input class="form-control form-control-sm"
                       style="max-width: 260px;"
                       placeholder="Search status"
                       value="@_searchStatus"
                       @oninput="@(e => { _searchStatus = e.Value?.ToString() ?? ""; _statusPage = 1; })" />
            </div>

            @if (!FilteredStatusRows.Any())
            {
                <div class="empty-state">No status codes found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th style="width: 120px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleStatusSort(nameof(StatusRow.StatusLabel))">Status @SortGlyph(_statusSortField, _statusSortDesc, nameof(StatusRow.StatusLabel))</button></th>
                                <th class="text-end" style="width: 140px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleStatusSort(nameof(StatusRow.CountLabel))">Count @SortGlyph(_statusSortField, _statusSortDesc, nameof(StatusRow.CountLabel))</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in PagedStatuses)
                            {
                                <tr>
                                    <td>@r.StatusLabel</td>
                                    <td class="text-end">@r.CountLabel</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pager CurrentPage="@_statusPage"
                       TotalPages="@StatusPageCount"
                       OnPageChanged="@(p => _statusPage = p)" />
            }
        }
        else if (ActiveTab == TabName.SlowPages)
        {
            <div class="grid-toolbar">
                <div><h3>Slow Pages</h3></div>
                <input class="form-control form-control-sm"
                       style="max-width: 260px;"
                       placeholder="Search slow pages"
                       value="@_searchSlow"
                       @oninput="@(e => { _searchSlow = e.Value?.ToString() ?? ""; _slowPage = 1; })" />
            </div>

            @if (!FilteredSlowPageRows.Any())
            {
                <div class="empty-state">No slow pages found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleSlowSort(nameof(SlowPageRow.Page))">Page @SortGlyph(_slowSortField, _slowSortDesc, nameof(SlowPageRow.Page))</button></th>
                                <th class="text-end" style="width: 160px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleSlowSort(nameof(SlowPageRow.AvgTimeLabel))">Avg Time (ms) @SortGlyph(_slowSortField, _slowSortDesc, nameof(SlowPageRow.AvgTimeLabel))</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in PagedSlowPages)
                            {
                                <tr>
                                    <td>@r.Page</td>
                                    <td class="text-end">@r.AvgTimeLabel</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pager CurrentPage="@_slowPage"
                       TotalPages="@SlowPageCount"
                       OnPageChanged="@(p => _slowPage = p)" />
            }
        }
        else if (ActiveTab == TabName.HourlyHits)
        {
            <div class="grid-toolbar">
                <div>
                    <h3>Hourly Hits</h3>
                    <div class="toolbar-subtle">Timezone: @LogParserService.TargetTimeZoneId</div>
                </div>
                <input class="form-control form-control-sm"
                       style="max-width: 260px;"
                       placeholder="Search hours"
                       value="@_searchHours"
                       @oninput="@(e => { _searchHours = e.Value?.ToString() ?? ""; _hourPage = 1; })" />
            </div>

            @if (!FilteredHourRows.Any())
            {
                <div class="empty-state">No hourly data found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th style="width: 120px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleHourSort(nameof(HourRow.HourLabel))">Hour @SortGlyph(_hourSortField, _hourSortDesc, nameof(HourRow.HourLabel))</button></th>
                                <th class="text-end" style="width: 140px;"><button type="button" class="btn btn-link btn-sm p-0" @onclick="() => ToggleHourSort(nameof(HourRow.HitsLabel))">Hits @SortGlyph(_hourSortField, _hourSortDesc, nameof(HourRow.HitsLabel))</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in PagedHours)
                            {
                                <tr>
                                    <td>
                                        <button type="button"
                                                class="btn btn-link btn-sm p-0"
                                                @onclick="() => OpenHourlyPopup(r.HourLabel)">
                                            @r.HourLabel
                                        </button>
                                    </td>
                                    <td class="text-end">@r.HitsLabel</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <Pager CurrentPage="@_hourPage"
                       TotalPages="@HourPageCount"
                       OnPageChanged="@(p => _hourPage = p)" />
            }

            <HourlyHitsDetailPopup IsOpen="@_showHourlyDetailsPopup"
                                   SelectedHour="@_selectedHour"
                                   ReportData="@ReportData"
                                   OnClose="CloseHourlyPopup" />
        }
    </div>
</div>

<style>
    .report-tabs {
        display: block;
    }

    .report-tabs__bar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .report-tabs__tab {
        border-radius: 999px;
    }

    .report-tabs__content {
        min-height: 240px;
    }

    .grid-toolbar {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 0.85rem;
    }

    .grid-toolbar h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: var(--shell-text) !important;
        opacity: 1 !important;
    }

    .toolbar-subtle {
        margin-top: 0.2rem;
        font-size: 0.8rem;
        color: var(--shell-subtle);
    }

    .empty-state {
        padding: 1rem 0.25rem 0.5rem;
        color: var(--shell-subtle);
    }

    @@media (max-width: 720px) {
        .grid-toolbar {
            align-items: stretch;
            flex-direction: column;
        }
    }
</style>

@code {
    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    private enum TabName
    {
        Pages,
        IPs,
        Errors,
        Documents,
        Popups,
        StatusCodes,
        SlowPages,
        HourlyHits
    }

    private static readonly IReadOnlyList<TabName> Tabs = new[]
    {
        TabName.Pages,
        TabName.IPs,
        TabName.Errors,
        TabName.Documents,
        TabName.Popups,
        TabName.StatusCodes,
        TabName.SlowPages,
        TabName.HourlyHits
    };

    private TabName ActiveTab { get; set; } = TabName.Pages;

    private string GetTabTitle(TabName tab)
    {
        var (name, count) = tab switch
        {
            TabName.Pages => ("Pages", ReportData?.PageHits?.Count ?? 0),
            TabName.IPs => ("IPs", ReportData?.TopIPs?.Count ?? 0),
            TabName.Errors => ("Errors", ReportData?.ErrorPages?.Count ?? 0),
            TabName.Documents => ("Documents", ReportData?.DocumentHits?.Count ?? 0),
            TabName.Popups => ("Popups", ReportData?.PopupHits?.Count ?? 0),
            TabName.StatusCodes => ("Status Codes", ReportData?.StatusCodes?.Count ?? 0),
            TabName.SlowPages => ("Slow Pages", ReportData?.SlowPages?.Count ?? 0),
            TabName.HourlyHits => ("Hourly Hits", ReportData?.HourlyHits?.Count ?? 0),
            _ => (tab.ToString(), 0)
        };

        return $"{name} ({count:N0})";
    }

    // Search strings for each distinct tab
    private string _searchPages = "";
    private string _searchIPs = "";
    private string _searchErrors = "";
    private string _searchDocs = "";
    private string _searchPopups = "";
    private string _searchStatus = "";
    private string _searchSlow = "";
    private string _searchHours = "";

    private IEnumerable<LabelValueRow> FilteredPageRows => FilterLabelValueRows(ReportData?.PageHits, _searchPages);
    private IEnumerable<LabelValueRow> FilteredIpRows => FilterLabelValueRows(ReportData?.TopIPs, _searchIPs);
    private IEnumerable<LabelValueRow> FilteredErrorRows => FilterLabelValueRows(ReportData?.ErrorPages, _searchErrors);
    private IEnumerable<LabelValueRow> FilteredPopupRows => FilterLabelValueRows(ReportData?.PopupHits, _searchPopups);
    private IEnumerable<DocumentRow> FilteredDocumentRows => (ReportData?.DocumentHits ?? [])
        .Select(item =>
        {
            var ext = Path.GetExtension(item.Key).ToLowerInvariant();
            var avgMs = ReportData?.DocumentAvgTime.GetValueOrDefault(item.Key) ?? 0;
            return new DocumentRow(
                item.Key,
                string.IsNullOrWhiteSpace(ext) ? "unknown" : ext.TrimStart('.'),
                item.Value.ToString("N0"),
                $"{avgMs:N0} ms");
        })
        .Where(item => FilterCore($"{item.File} {item.TypeLabel}", _searchDocs))
        .OrderByDescending(item => int.Parse(item.DownloadsLabel.Replace(",", string.Empty)));

    private IEnumerable<StatusRow> FilteredStatusRows => (ReportData?.StatusCodes ?? [])
        .OrderByDescending(item => item.Value)
        .Select(item => new StatusRow(item.Key.ToString(), item.Value.ToString("N0")))
        .Where(item => FilterCore(item.StatusLabel, _searchStatus));

    private IEnumerable<SlowPageRow> FilteredSlowPageRows => (ReportData?.SlowPages ?? [])
        .Select(item => new SlowPageRow(item.Key, $"{item.Value:N0} ms"))
        .Where(item => FilterCore(item.Page, _searchSlow))
        .OrderByDescending(item => ParseMetric(item.AvgTimeLabel));

    private IEnumerable<HourRow> FilteredHourRows => (ReportData?.HourlyHits ?? [])
        .OrderByDescending(item => item.Value)
        .Select(item => new HourRow(item.Key.ToString("D2"), item.Value.ToString("N0")))
        .Where(item => FilterCore(item.HourLabel, _searchHours));

    private bool FilterCore(string search, string searchStr)
    {
        if (string.IsNullOrWhiteSpace(searchStr))
            return true;
        return search.Contains(searchStr, StringComparison.OrdinalIgnoreCase);
    }

    private IEnumerable<LabelValueRow> FilterLabelValueRows(IEnumerable<KeyValuePair<string, int>>? source, string searchText) =>
        (source ?? [])
            .Where(item => FilterCore(item.Key, searchText))
            .OrderByDescending(item => item.Value)
            .Select(item => new LabelValueRow(item.Key, item.Value.ToString("N0")));

    private static int ParseMetric(string value) =>
        int.TryParse(value.Replace(" ms", string.Empty).Replace(",", string.Empty), out var parsed) ? parsed : 0;

    private sealed record DocumentRow(string File, string TypeLabel, string DownloadsLabel, string AvgTimeLabel);
    private sealed record StatusRow(string StatusLabel, string CountLabel);
    private sealed record SlowPageRow(string Page, string AvgTimeLabel);
    private sealed record HourRow(string HourLabel, string HitsLabel);

    private const int PageSize = 12;

    private int _docPage = 1;
    private int _statusPage = 1;
    private int _slowPage = 1;
    private int _hourPage = 1;

    private string _docSortField = nameof(DocumentRow.DownloadsLabel);
    private bool _docSortDesc = true;

    private string _statusSortField = nameof(StatusRow.CountLabel);
    private bool _statusSortDesc = true;

    private string _slowSortField = nameof(SlowPageRow.AvgTimeLabel);
    private bool _slowSortDesc = true;

    private string _hourSortField = nameof(HourRow.HitsLabel);
    private bool _hourSortDesc = true;

    private bool _showHourlyDetailsPopup;
    private int _selectedHour;

    private static int ParseNumber(string formatted) =>
        int.TryParse(formatted.Replace(",", string.Empty), out var parsed) ? parsed : 0;

    private IEnumerable<DocumentRow> SortDocuments(IEnumerable<DocumentRow> rows, string sortField, bool desc)
    {
        Func<DocumentRow, object> keySelector = sortField switch
        {
            nameof(DocumentRow.File) => r => r.File,
            nameof(DocumentRow.TypeLabel) => r => r.TypeLabel,
            nameof(DocumentRow.AvgTimeLabel) => r => ParseMetric(r.AvgTimeLabel),
            _ => r => ParseNumber(r.DownloadsLabel)
        };
        return desc ? rows.OrderByDescending(keySelector) : rows.OrderBy(keySelector);
    }

    private IEnumerable<StatusRow> SortStatus(IEnumerable<StatusRow> rows, string sortField, bool desc)
    {
        Func<StatusRow, object> keySelector = sortField switch
        {
            nameof(StatusRow.StatusLabel) => r => ParseNumber(r.StatusLabel),
            _ => r => ParseNumber(r.CountLabel)
        };
        return desc ? rows.OrderByDescending(keySelector) : rows.OrderBy(keySelector);
    }

    private IEnumerable<SlowPageRow> SortSlow(IEnumerable<SlowPageRow> rows, string sortField, bool desc)
    {
        Func<SlowPageRow, object> keySelector = sortField switch
        {
            nameof(SlowPageRow.Page) => r => r.Page,
            _ => r => ParseMetric(r.AvgTimeLabel)
        };
        return desc ? rows.OrderByDescending(keySelector) : rows.OrderBy(keySelector);
    }

    private IEnumerable<HourRow> SortHours(IEnumerable<HourRow> rows, string sortField, bool desc)
    {
        Func<HourRow, object> keySelector = sortField switch
        {
            nameof(HourRow.HourLabel) => r => ParseNumber(r.HourLabel),
            _ => r => ParseNumber(r.HitsLabel)
        };
        return desc ? rows.OrderByDescending(keySelector) : rows.OrderBy(keySelector);
    }

    private static string SortGlyph(string activeField, bool desc, string field) =>
        activeField == field ? (desc ? "▼" : "▲") : "";

    private List<DocumentRow> SortedDocuments =>
        SortDocuments(FilteredDocumentRows, _docSortField, _docSortDesc).ToList();

    private int DocPageCount => Math.Max(1, (int)Math.Ceiling(SortedDocuments.Count / (double)PageSize));

    private IEnumerable<DocumentRow> PagedDocuments =>
        SortedDocuments
            .Skip((Math.Clamp(_docPage, 1, DocPageCount) - 1) * PageSize)
            .Take(PageSize);

    private void ToggleDocSort(string field) => ToggleSort(ref _docSortField, ref _docSortDesc, field);

    private List<StatusRow> SortedStatuses =>
        SortStatus(FilteredStatusRows, _statusSortField, _statusSortDesc).ToList();

    private int StatusPageCount => Math.Max(1, (int)Math.Ceiling(SortedStatuses.Count / (double)PageSize));

    private IEnumerable<StatusRow> PagedStatuses =>
        SortedStatuses
            .Skip((Math.Clamp(_statusPage, 1, StatusPageCount) - 1) * PageSize)
            .Take(PageSize);

    private void ToggleStatusSort(string field) => ToggleSort(ref _statusSortField, ref _statusSortDesc, field);

    private List<SlowPageRow> SortedSlowPages =>
        SortSlow(FilteredSlowPageRows, _slowSortField, _slowSortDesc).ToList();

    private int SlowPageCount => Math.Max(1, (int)Math.Ceiling(SortedSlowPages.Count / (double)PageSize));

    private IEnumerable<SlowPageRow> PagedSlowPages =>
        SortedSlowPages
            .Skip((Math.Clamp(_slowPage, 1, SlowPageCount) - 1) * PageSize)
            .Take(PageSize);

    private void ToggleSlowSort(string field) => ToggleSort(ref _slowSortField, ref _slowSortDesc, field);

    private List<HourRow> SortedHours =>
        SortHours(FilteredHourRows, _hourSortField, _hourSortDesc).ToList();

    private int HourPageCount => Math.Max(1, (int)Math.Ceiling(SortedHours.Count / (double)PageSize));

    private IEnumerable<HourRow> PagedHours =>
        SortedHours
            .Skip((Math.Clamp(_hourPage, 1, HourPageCount) - 1) * PageSize)
            .Take(PageSize);

    private void ToggleHourSort(string field) => ToggleSort(ref _hourSortField, ref _hourSortDesc, field);

    private static void ToggleSort(ref string sortField, ref bool sortDesc, string field)
    {
        if (sortField == field)
        {
            sortDesc = !sortDesc;
            return;
        }

        sortField = field;
        sortDesc = true;
    }

    private void OpenHourlyPopup(string hourLabel)
    {
        if (!int.TryParse(hourLabel, out var parsedHour))
            return;

        _selectedHour = parsedHour;
        _showHourlyDetailsPopup = true;
    }

    private void CloseHourlyPopup()
    {
        _showHourlyDetailsPopup = false;
    }
}
