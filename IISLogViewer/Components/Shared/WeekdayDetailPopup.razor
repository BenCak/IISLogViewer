@inject IISLogViewer.Services.LogParserService LogParserService

@if (IsOpen)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.2);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Weekday Details - @SelectedWeekdayLabel</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body">
                    <section class="weekday-section">
                        <button type="button" class="weekday-section__toggle" @onclick="() => ToggleSection(SectionPages)">Top Pages</button>
                        @if (IsSectionOpen(SectionPages))
                        {
                            <div class="weekday-section__content">@RenderList(TopPages, "No page hits for this day.", "Page")</div>
                        }
                    </section>

                    <section class="weekday-section">
                        <button type="button" class="weekday-section__toggle" @onclick="() => ToggleSection(SectionUsers)">Most Active Users</button>
                        @if (IsSectionOpen(SectionUsers))
                        {
                            <div class="weekday-section__content">@RenderList(TopUsers, "No user hits for this day.", "User")</div>
                        }
                    </section>

                    <section class="weekday-section">
                        <button type="button" class="weekday-section__toggle" @onclick="() => ToggleSection(SectionPopups)">Top Popups</button>
                        @if (IsSectionOpen(SectionPopups))
                        {
                            <div class="weekday-section__content">@RenderList(TopPopups, "No popup hits for this day.", "Popup")</div>
                        }
                    </section>

                    <section class="weekday-section">
                        <button type="button" class="weekday-section__toggle" @onclick="() => ToggleSection(SectionDocuments)">Top Documents</button>
                        @if (IsSectionOpen(SectionDocuments))
                        {
                            <div class="weekday-section__content">@RenderList(TopDocuments, "No document hits for this day.", "Document")</div>
                        }
                    </section>

                    <section class="weekday-section mb-0">
                        <button type="button" class="weekday-section__toggle" @onclick="() => ToggleSection(SectionHours)">Most Active Hours</button>
                        @if (IsSectionOpen(SectionHours))
                        {
                            <div class="weekday-section__content">@RenderHourList(TopHours, "No hourly hits for this day.")</div>
                        }
                    </section>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Close">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .weekday-section {
        margin-bottom: 1rem;
        border: 1px solid var(--bs-border-color);
        border-radius: 0.35rem;
        background: var(--bs-body-bg);
    }

    .weekday-section__toggle {
        width: 100%;
        border: 0;
        background: transparent;
        padding: 0.55rem 0.7rem;
        text-align: left;
        font-weight: 600;
        cursor: pointer;
    }

    .weekday-section__content {
        border-bottom: 1px solid var(--bs-border-color);
        padding: 0.25rem 0.6rem 0.35rem;
    }

    .weekday-section .table {
        table-layout: fixed;
        width: 100%;
    }

    .weekday-section .table th:first-child,
    .weekday-section .table td:first-child {
        width: calc(100% - 88px);
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .weekday-section .table th:last-child,
    .weekday-section .table td:last-child {
        width: 88px;
        white-space: nowrap;
    }
</style>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public int SelectedWeekday { get; set; }

    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private const string SectionPages = "pages";
    private const string SectionUsers = "users";
    private const string SectionPopups = "popups";
    private const string SectionDocuments = "documents";
    private const string SectionHours = "hours";

    private string _openSection = SectionPages;

    private const int MaxRows = 12;

    private string SelectedWeekdayLabel => DayLabel(SelectedWeekday);

    private IEnumerable<KeyValuePair<string, int>> TopPages =>
        GetTopByWeekday(ReportData?.WeekdayPageHits, SelectedWeekday);

    private IEnumerable<KeyValuePair<string, int>> TopPopups =>
        GetTopByWeekday(ReportData?.WeekdayPopupHits, SelectedWeekday);

    private IEnumerable<KeyValuePair<string, int>> TopDocuments =>
        GetTopByWeekday(ReportData?.WeekdayDocumentHits, SelectedWeekday);

    private IEnumerable<KeyValuePair<string, int>> TopUsers =>
        GetTopUsersByWeekday(ReportData?.WeekdayUserHits, SelectedWeekday);

    private IEnumerable<KeyValuePair<int, int>> TopHours =>
        GetTopHoursByWeekday(ReportData?.WeekdayHourHits, SelectedWeekday);

    private static IEnumerable<KeyValuePair<string, int>> GetTopByWeekday(
        Dictionary<int, Dictionary<string, int>>? source,
        int weekday)
    {
        if (source == null || !source.TryGetValue(weekday, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<string, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Take(MaxRows);
    }

    private IEnumerable<KeyValuePair<string, int>> GetTopUsersByWeekday(
        Dictionary<int, Dictionary<string, int>>? source,
        int weekday)
    {
        if (source == null || !source.TryGetValue(weekday, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<string, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
            .Take(MaxRows)
            .Select(item =>
            {
                var displayName = LogParserService.GetUserDisplayName(item.Key);
                var label = string.Equals(displayName, item.Key, StringComparison.OrdinalIgnoreCase)
                    ? item.Key
                    : $"{displayName} ({item.Key})";
                return new KeyValuePair<string, int>(label, item.Value);
            });
    }

    private static IEnumerable<KeyValuePair<int, int>> GetTopHoursByWeekday(
        Dictionary<int, Dictionary<int, int>>? source,
        int weekday)
    {
        if (source == null || !source.TryGetValue(weekday, out var bucket) || bucket.Count == 0)
            return Enumerable.Empty<KeyValuePair<int, int>>();

        return bucket
            .OrderByDescending(x => x.Value)
            .ThenBy(x => x.Key)
            .Take(MaxRows);
    }

    private static string DayLabel(int dayIndex)
    {
        if (dayIndex is < 0 or > 6)
            return $"Day {dayIndex}";

        return ((DayOfWeek)dayIndex).ToString();
    }

    private RenderFragment RenderList(IEnumerable<KeyValuePair<string, int>> rows, string emptyMessage, string itemHeader) => builder =>
    {
        var list = rows.ToList();
        if (!list.Any())
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "text-muted small");
            builder.AddContent(2, emptyMessage);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(3, "table");
        builder.AddAttribute(4, "class", "table table-sm align-middle mb-0");

        builder.OpenElement(5, "thead");
        builder.OpenElement(6, "tr");
        builder.OpenElement(7, "th");
        builder.AddContent(8, itemHeader);
        builder.CloseElement();
        builder.OpenElement(9, "th");
        builder.AddAttribute(10, "class", "text-end");
        builder.AddContent(11, "Hits");
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(12, "tbody");
        var seq = 13;
        foreach (var row in list)
        {
            builder.OpenElement(seq++, "tr");

            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "small");
            builder.AddContent(seq++, row.Key);
            builder.CloseElement();

            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "text-end");
            builder.AddContent(seq++, row.Value.ToString("N0"));
            builder.CloseElement();

            builder.CloseElement();
        }
        builder.CloseElement();

        builder.CloseElement();
    };

    private RenderFragment RenderHourList(IEnumerable<KeyValuePair<int, int>> rows, string emptyMessage) => builder =>
    {
        var list = rows.ToList();
        if (!list.Any())
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "text-muted small");
            builder.AddContent(2, emptyMessage);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(3, "table");
        builder.AddAttribute(4, "class", "table table-sm align-middle mb-0");

        builder.OpenElement(5, "thead");
        builder.OpenElement(6, "tr");
        builder.OpenElement(7, "th");
        builder.AddContent(8, "Hour");
        builder.CloseElement();
        builder.OpenElement(9, "th");
        builder.AddAttribute(10, "class", "text-end");
        builder.AddContent(11, "Hits");
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(12, "tbody");
        var seq = 13;
        foreach (var row in list)
        {
            builder.OpenElement(seq++, "tr");

            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "small");
            builder.AddContent(seq++, $"{row.Key:D2}:00-{row.Key:D2}:59");
            builder.CloseElement();

            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "text-end");
            builder.AddContent(seq++, row.Value.ToString("N0"));
            builder.CloseElement();

            builder.CloseElement();
        }
        builder.CloseElement();

        builder.CloseElement();
    };

    private Task Close() => OnClose.InvokeAsync();

    private void ToggleSection(string section)
    {
        _openSection = _openSection == section ? string.Empty : section;
    }

    private bool IsSectionOpen(string section) =>
        string.Equals(_openSection, section, StringComparison.OrdinalIgnoreCase);
}
