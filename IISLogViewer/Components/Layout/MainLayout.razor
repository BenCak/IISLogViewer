@inherits LayoutComponentBase
@rendermode InteractiveServer

<div class="app-shell">
    <header class="app-shell__header">
        <div>
            <div class="app-shell__title">IIS Log Viewer</div>
            <div class="app-shell__subtitle">W3SVC2 analytics workspace</div>
        </div>
    </header>

    <div class="app-shell__body">
        <aside class="app-shell__sidebar">
            <div class="app-shell__sidebar-title">Log Files</div>
            <NavMenu />
        </aside>

        <main class="app-shell__content">
            @Body
        </main>
    </div>
</div>

<style>
    .app-shell {
        --shell-bg: #f8f9fa;
        --shell-panel: #ffffff;
        --shell-panel-muted: #e9ecef;
        --shell-border: #dee2e6;
        --shell-text: #212529;
        --shell-subtle: #6c757d;
        --shell-primary: #0d6efd;
        --shell-accent: #7952b3;
        min-height: 100vh;
        background:
            radial-gradient(circle at top right, rgba(13, 110, 253, 0.12), transparent 30%),
            linear-gradient(180deg, #f8fbff 0%, var(--shell-bg) 65%);
        color: var(--shell-text);
    }

    .app-shell__header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        padding: 1.5rem 1.75rem 1rem;
        border-bottom: 1px solid var(--shell-border);
        background:
            radial-gradient(circle at top left, color-mix(in srgb, var(--shell-primary) 55%, transparent), transparent 55%),
            linear-gradient(135deg, color-mix(in srgb, var(--shell-accent) 70%, var(--shell-primary)), var(--shell-panel));
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(12px);
    }

    .app-shell__title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .app-shell__subtitle,
    .app-shell__label {
        color: var(--shell-text);
        font-size: 0.85rem;
    }

    .app-shell__body {
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        gap: 1.25rem;
        padding: 1.25rem;
    }

    .app-shell__sidebar,
    .app-shell__content {
        background: var(--shell-panel);
        border: 1px solid var(--shell-border);
        border-radius: 20px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .app-shell__sidebar {
        padding: 1rem 0.75rem;
        position: sticky;
        top: 6.25rem;
        max-height: calc(100vh - 7.5rem);
        overflow: auto;
    }

    .app-shell__sidebar-title {
        padding: 0 0.5rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--shell-subtle);
    }

    .app-shell__content {
        padding: 1.25rem;
    }

    .app-shell :is(h1, h2, h3, h4, h5, h6, p, span, div, strong, label, a) {
        color: inherit;
    }

    @@media (max-width: 960px) {
        .app-shell__body {
            grid-template-columns: 1fr;
        }

        .app-shell__sidebar {
            position: static;
            max-height: none;
        }

        .app-shell__header {
            align-items: start;
            flex-direction: column;
        }
    }
</style>
