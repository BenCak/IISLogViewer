@inherits LayoutComponentBase
@rendermode InteractiveServer

<div class="app-shell @_selectedTheme.CssClass">
    <header class="app-shell__header">
        <div>
            <div class="app-shell__title">IIS Log Viewer</div>
            <div class="app-shell__subtitle">W3SVC2 analytics workspace</div>
        </div>

        <div class="app-shell__theme-picker">
            <label class="app-shell__label" for="theme-selector">Theme</label>
            <select id="theme-selector"
                    class="form-select form-select-sm app-shell__select"
                    value="@_selectedTheme.Name"
                    @onchange="OnThemeChanged">
                @foreach (var name in ThemeNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
        </div>
    </header>

    <div class="app-shell__body">
        <aside class="app-shell__sidebar">
            <div class="app-shell__sidebar-title">Log Files</div>
            <NavMenu />
        </aside>

        <main class="app-shell__content">
            @Body
        </main>
    </div>
</div>

<style>
    .app-shell {
        --shell-bg: #f3f7fb;
        --shell-panel: #ffffff;
        --shell-panel-muted: #eef3f9;
        --shell-border: #d7e0ec;
        --shell-text: #112033;
        --shell-subtle: #5b6b83;
        --shell-primary: #0d6efd;
        --shell-accent: #1f3c88;
        min-height: 100vh;
        background:
            radial-gradient(circle at top right, rgba(13, 110, 253, 0.12), transparent 30%),
            linear-gradient(180deg, #f8fbff 0%, var(--shell-bg) 65%);
        color: var(--shell-text);
    }

    .app-shell.theme-bootstrap {
        --shell-bg: #f8f9fa;
        --shell-panel: #ffffff;
        --shell-panel-muted: #e9ecef;
        --shell-border: #dee2e6;
        --shell-text: #212529;
        --shell-subtle: #6c757d;
        --shell-primary: #0d6efd;
        --shell-accent: #6f42c1;
    }

    .app-shell.theme-material {
        --shell-bg: #fafafa;
        --shell-panel: #ffffff;
        --shell-panel-muted: #eeeeee;
        --shell-border: #e0e0e0;
        --shell-text: #212121;
        --shell-subtle: #757575;
        --shell-primary: #2196f3;
        --shell-accent: #1565c0;
    }

    .app-shell.theme-fluent {
        --shell-bg: #f3f2f1;
        --shell-panel: #ffffff;
        --shell-panel-muted: #edebe9;
        --shell-border: #e1dfdd;
        --shell-text: #201f1e;
        --shell-subtle: #605e5c;
        --shell-primary: #0078d4;
        --shell-accent: #106ebe;
    }

    .app-shell.theme-black {
        --shell-bg: #1a1a1a;
        --shell-panel: #262626;
        --shell-panel-muted: #0f0f0f;
        --shell-border: #404040;
        --shell-text: #e8e8e8;
        --shell-subtle: #909090;
        --shell-primary: #00bfff;
        --shell-accent: #2a2a2a;
    }

    .app-shell__header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        padding: 1.5rem 1.75rem 1rem;
        border-bottom: 1px solid var(--shell-border);
        background: linear-gradient(135deg, var(--shell-accent), var(--shell-panel));
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(12px);
    }

    .app-shell__title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .app-shell__subtitle,
    .app-shell__label {
        color: var(--shell-text);
        font-size: 0.85rem;
    }

    .app-shell__theme-picker {
        min-width: 220px;
    }

    .app-shell__select {
        border-radius: 12px;
        border-color: var(--shell-border);
        background-color: var(--shell-panel);
        color: inherit;
        box-shadow: none;
    }

    .app-shell__body {
        display: grid;
        grid-template-columns: 320px minmax(0, 1fr);
        gap: 1.25rem;
        padding: 1.25rem;
    }

    .app-shell__sidebar,
    .app-shell__content {
        background: var(--shell-panel);
        border: 1px solid var(--shell-border);
        border-radius: 20px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .app-shell__sidebar {
        padding: 1rem 0.75rem;
        position: sticky;
        top: 6.25rem;
        max-height: calc(100vh - 7.5rem);
        overflow: auto;
    }

    .app-shell__sidebar-title {
        padding: 0 0.5rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--shell-subtle);
    }

    .app-shell__content {
        padding: 1.25rem;
    }

    .app-shell :is(h1, h2, h3, h4, h5, h6, p, span, div, strong, label, a) {
        color: inherit;
    }

    @@media (max-width: 960px) {
        .app-shell__body {
            grid-template-columns: 1fr;
        }

        .app-shell__sidebar {
            position: static;
            max-height: none;
        }

        .app-shell__header {
            align-items: start;
            flex-direction: column;
        }
    }
</style>

@code {
    private ThemeOption _selectedTheme = ThemeOptions[0];

    private static IReadOnlyList<string> ThemeNames => ThemeOptions.Select(x => x.Name).ToList();

    private static readonly IReadOnlyList<ThemeOption> ThemeOptions = new[]
    {
        new ThemeOption("Default", "theme-default"),
        new ThemeOption("Bootstrap", "theme-bootstrap"),
        new ThemeOption("Material", "theme-material"),
        new ThemeOption("Fluent", "theme-fluent"),
        new ThemeOption("Black", "theme-black")
    };

    private void OnThemeChanged(ChangeEventArgs e)
    {
        var themeName = e.Value?.ToString() ?? ThemeOptions[0].Name;
        _selectedTheme = ThemeOptions.FirstOrDefault(x => x.Name == themeName) ?? ThemeOptions[0];
    }

    private sealed record ThemeOption(string Name, string CssClass);
}
