    protected override void OnInitialized()
    {
        var entry = _themes[_selectedTheme];
        _currentTheme = entry.Theme;
        _isDarkMode = entry.IsDark;
    }

    private void OnThemeChanged(string themeName)
    {
        _selectedTheme = themeName;
        var entry = _themes[themeName];
        _currentTheme = entry.Theme;
        _isDarkMode = entry.IsDark;
        StateHasChanged();
    }
}