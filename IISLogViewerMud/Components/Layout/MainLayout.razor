@inherits LayoutComponentBase
@rendermode InteractiveServer

<MudThemeProvider Theme="_currentTheme" IsDarkMode="_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudText Typo="Typo.h6" Class="ml-3">IIS Log Viewer — WSSVC2</MudText>
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <div class="pa-4" style="min-width:220px;">
                <MudText Typo="Typo.subtitle2" Class="mb-2"><b>Theme</b></MudText>
                <MudSelect T="string" Value="_selectedTheme" ValueChanged="OnThemeChanged"
                           Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                           Label="Color Theme">
                    @foreach (var name in _themes.Keys)
                    {
                        <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
                    }
                </MudSelect>
            </div>
        </MudMenu>
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1"><b>Log Files</b></MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

