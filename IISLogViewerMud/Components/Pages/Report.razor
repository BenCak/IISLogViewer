<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" KeepPanelsAlive="false">
    <MudTabPanel Text="Pages" Icon="@Icons.Material.Filled.Web">
        <MudTable Items="@ReportData?.PageHits" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<string, int>,bool>(FilterPages)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">All Pages</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchPages" Placeholder="Search Pages" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Page</MudTh>
                <MudTh>Hits</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Key</MudTd>
                <MudTd>@context.Value.ToString("N0")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="IPs" Icon="@Icons.Material.Filled.Computer">
        <MudTable Items="@ReportData?.TopIPs" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<string, int>,bool>(FilterIPs)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">IP Addresses</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchIPs" Placeholder="Search IPs" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>IP Address</MudTh>
                <MudTh>Hits</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Key</MudTd>
                <MudTd>@context.Value.ToString("N0")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Errors" Icon="@Icons.Material.Filled.Error">
        <MudTable Items="@ReportData?.ErrorPages" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<string, int>,bool>(FilterErrors)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Error Pages</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_searchErrors" Placeholder="Search Errors" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Page</MudTh>
                <MudTh>Hits</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Key</MudTd>
                <MudTd>@context.Value.ToString("N0")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.FileDownload">
        @if (ReportData?.DocumentHits.Any() == true)
        {
            <MudTable Items="@ReportData.DocumentHits" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<string, int>,bool>(FilterDocs)">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Documents</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchDocs" Placeholder="Search Documents" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>File</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Downloads</MudTh>
                    <MudTh>Avg Time</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Key</MudTd>
                    <MudTd>
                        @{
                            var ext = System.IO.Path.GetExtension(context.Key).ToLower();
                        }
                        <MudChip T="string" Size="Size.Small"
                            Color="@(ext == ".pdf" ? Color.Error : ext == ".exe" ? Color.Warning : Color.Info)">
                            @ext.TrimStart('.')
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.Value.ToString("N0")</MudTd>
                    <MudTd>
                        @{
                            var avgMs = ReportData.DocumentAvgTime.GetValueOrDefault(context.Key);
                        }
                        <MudChip T="string" Size="Size.Small" Color="@GetTimeTakenColor(avgMs)">
                            @avgMs.ToString("N0") ms
                        </MudChip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">No document downloads found.</MudAlert>
        }
    </MudTabPanel>

    <MudTabPanel Text="Popups" Icon="@Icons.Material.Filled.OpenInNew">
        @if (ReportData?.PopupHits.Any() == true)
        {
            <MudTable Items="@ReportData.PopupHits" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<string, int>,bool>(FilterPopups)">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Popups</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchPopups" Placeholder="Search Popups" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Type</MudTh>
                    <MudTh>Hits</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Key</MudTd>
                    <MudTd>@context.Value.ToString("N0")</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">No popup control types found.</MudAlert>
        }
    </MudTabPanel>

    <MudTabPanel Text="Status Codes" Icon="@Icons.Material.Filled.Code">
        @if (ReportData?.StatusCodes.Any() == true)
        {
            <MudTable Items="@ReportData.StatusCodes.OrderByDescending(x => x.Value)" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<int, int>,bool>(FilterStatus)">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Status Codes</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchStatus" Placeholder="Search Status" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Status</MudTh>
                    <MudTh>Count</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Color="@GetStatusColor(context.Key)" Size="Size.Small">
                            @context.Key
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.Value.ToString("N0")</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
        else
        {
           <MudAlert Severity="Severity.Info" Dense="true">No status codes found.</MudAlert> 
        }
    </MudTabPanel>

    <MudTabPanel Text="Slow Pages" Icon="@Icons.Material.Filled.Timer">
        @if (ReportData?.SlowPages.Any() == true)
        {
            <MudTable Items="@ReportData.SlowPages" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<string, int>,bool>(FilterSlow)">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Slow Pages</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchSlow" Placeholder="Search Slow Pages" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Page</MudTh>
                    <MudTh>Avg Time (ms)</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Key</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetTimeTakenColor(context.Value)">
                            @context.Value.ToString("N0") ms
                        </MudChip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">No slow pages found.</MudAlert>
        }
    </MudTabPanel>

    <MudTabPanel Text="Hourly Hits" Icon="@Icons.Material.Filled.Schedule">
        @if (ReportData?.HourlyHits.Any() == true)
        {
            <MudTable Items="@ReportData.HourlyHits.OrderByDescending(x => x.Value)" Dense="true" Hover="true" Striped="true" Filter="new Func<KeyValuePair<int, int>,bool>(FilterHours)">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Hourly Hits</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchHours" Placeholder="Search Hours" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Hour</MudTh>
                    <MudTh>Hits</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Key</MudTd>
                    <MudTd>@context.Value.ToString("N0")</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">No hourly data found.</MudAlert>
        }
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter]
    public IISLogViewer.Services.LogReport? ReportData { get; set; }

    // Search strings for each distinct tab
    private string _searchPages = "";
    private string _searchIPs = "";
    private string _searchErrors = "";
    private string _searchDocs = "";
    private string _searchPopups = "";
    private string _searchStatus = "";
    private string _searchSlow = "";
    private string _searchHours = "";

    // Specific filter funcs for each table type depending on its text field
    private bool FilterPages(KeyValuePair<string, int> element) => FilterCore(element.Key, _searchPages);
    private bool FilterIPs(KeyValuePair<string, int> element) => FilterCore(element.Key, _searchIPs);
    private bool FilterErrors(KeyValuePair<string, int> element) => FilterCore(element.Key, _searchErrors);
    private bool FilterDocs(KeyValuePair<string, int> element) => FilterCore(element.Key, _searchDocs);
    private bool FilterPopups(KeyValuePair<string, int> element) => FilterCore(element.Key, _searchPopups);
    private bool FilterStatus(KeyValuePair<int, int> element) => FilterCore(element.Key.ToString(), _searchStatus);
    private bool FilterSlow(KeyValuePair<string, int> element) => FilterCore(element.Key, _searchSlow);
    private bool FilterHours(KeyValuePair<int, int> element) => FilterCore(element.Key.ToString(), _searchHours);

    private bool FilterCore(string search, string searchStr)
    {
        if (string.IsNullOrWhiteSpace(searchStr))
            return true;
        if (search.Contains(searchStr, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private Color GetStatusColor(int status) => status switch
    {
        >= 500 => Color.Error,
        >= 400 => Color.Warning,
        >= 300 => Color.Info,
        >= 200 => Color.Success,
        _ => Color.Default
    };

    private Color GetTimeTakenColor(int ms) => ms switch
    {
        >= 5000 => Color.Error,
        >= 2000 => Color.Warning,
        >= 500 => Color.Info,
        _ => Color.Success
    };
}
